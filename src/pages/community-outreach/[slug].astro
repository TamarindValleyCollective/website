---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('communityOutreach');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <PageHero eyebrow="Community Outreach" title={post.data.title} image={post.data.coverImage} imageAlt={post.data.title} />
  <article class="section wrapper prose">
    <Content />
  </article>
</BaseLayout>

<style>
  .prose :global(img) {
    border-radius: var(--radius);
    margin: 16px 0;
  }
</style>
