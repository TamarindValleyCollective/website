---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const allEvents = (await getCollection('events', (e) => !e.data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const now = new Date();
const upcoming = allEvents.filter((e) => e.data.date >= now);
const past = allEvents.filter((e) => e.data.date < now);

const formatDate = (d: Date) => d.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Events" description="Upcoming and past events at Tamarind Valley Collective — camps, workshops, biodiversity walks, and retreats." image="/images/events/2026-08-01-foraging-day/hero.jpeg" imageWidth={720} imageHeight={480}>
  <PageHero eyebrow="Events" title="Upcoming & Past Events" image="/images/events/2026-08-01-foraging-day/hero.jpeg" imageAlt="A group foraging walk through the farm's greenery" />

  <section class="section wrapper">
    <h2>Upcoming</h2>
    {upcoming.length > 0 ? (
      <div class="grid">
        {upcoming.map((e) => (
          <a class="card" href={`/events/${e.id}`}>
            {e.data.coverImage && <img src={e.data.coverImage} alt={e.data.title} />}
            <p class="date">{formatDate(e.data.date)}</p>
            <h3>{e.data.title}</h3>
            <p>{e.data.excerpt}</p>
            {e.data.tags.length > 0 && (
              <ul class="tags">
                {e.data.tags.map((t) => <li class="tag">{t}</li>)}
              </ul>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p>No events currently planned — check back soon.</p>
    )}
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <h2>Past events</h2>
      <div class="grid">
        {past.map((e) => (
          <a class="card" href={`/events/${e.id}`}>
            {e.data.coverImage && <img src={e.data.coverImage} alt={e.data.title} />}
            <p class="date">{formatDate(e.data.date)}</p>
            <h3>{e.data.title}</h3>
            <p>{e.data.excerpt}</p>
            {e.data.tags.length > 0 && (
              <ul class="tags">
                {e.data.tags.map((t) => <li class="tag">{t}</li>)}
              </ul>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }

  .grid a {
    text-decoration: none;
    color: inherit;
  }

  .grid img {
    border-radius: var(--radius) var(--radius) 0 0;
    margin: -24px -24px 16px;
    width: calc(100% + 48px);
    height: 160px;
    object-fit: cover;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 10px 0 0;
    padding: 0;
  }

  .tag {
    background: var(--tvc-green-tint);
    color: var(--tvc-green-dark);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 0.76rem;
    font-weight: 600;
  }

  .date {
    color: var(--tvc-orange);
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 4px;
  }
</style>
