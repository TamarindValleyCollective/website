---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection, render } from 'astro:content';
import { formatDateRange, durationTag } from '../../utils/events';

export async function getStaticPaths() {
  const events = await getCollection('events', (e) => !e.data.draft);
  return events.map((event) => ({ params: { slug: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.data.title,
  startDate: event.data.date.toISOString().slice(0, 10),
  endDate: event.data.endDate ? event.data.endDate.toISOString().slice(0, 10) : undefined,
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  description: event.data.excerpt,
  image: event.data.coverImage ? new URL(event.data.coverImage, Astro.site).toString() : undefined,
  location: {
    '@type': 'Place',
    name: 'Tamarind Valley Collective',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Thaggatti village',
      addressLocality: 'Kanakapura',
      addressRegion: 'Karnataka',
      addressCountry: 'IN',
    },
  },
  organizer: event.data.organizer
    ? { '@type': 'Organization', name: event.data.organizer }
    : { '@type': 'Organization', name: 'Tamarind Valley Collective', url: new URL('/', Astro.site).toString() },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'Events', item: new URL('/events', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: event.data.title },
  ],
};
---

<BaseLayout title={event.data.title} description={event.data.excerpt} image={event.data.coverImage} schema={[eventSchema, breadcrumbSchema]}>
  <PageHero eyebrow={formatDateRange(event.data.date, event.data.endDate)} title={event.data.title} image={event.data.coverImage} imageAlt={event.data.title} />
  <article class="section wrapper prose">
    <div class="meta">
      {event.data.organizer && <p class="organizer">Organized by {event.data.organizer}</p>}
      <ul class="tags">
        {event.data.tags.map((t) => <li class="tag">{t}</li>)}
        <li class="tag tag--duration">{durationTag(event.data.date, event.data.endDate)}</li>
      </ul>
    </div>
    <Content />
  </article>
</BaseLayout>

<style>
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .organizer {
    margin: 0;
    color: var(--tvc-ink-soft);
    font-size: 0.9rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag {
    background: var(--tvc-green-tint);
    color: var(--tvc-green-dark);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 0.76rem;
    font-weight: 600;
  }

  .tag--duration {
    background: var(--tvc-orange-tint);
    color: #a85712;
  }

  .prose :global(h2) {
    margin-top: 32px;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--tvc-orange);
    padding-left: 20px;
    font-style: italic;
    color: var(--tvc-ink-soft);
  }

  .prose :global(img) {
    border-radius: var(--radius);
    margin: 16px 0;
  }

  .prose :global(table) {
    width: 100%;
    max-width: 72ch;
    border-collapse: collapse;
    margin: 16px 0 32px;
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 10px 16px;
    border-bottom: 1px solid var(--tvc-line);
  }

  .prose :global(th) {
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: var(--tvc-orange);
  }

  .prose :global(td:first-child) {
    color: var(--tvc-ink-soft);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .prose :global(.cta) {
    max-width: 72ch;
    margin: 32px 0;
  }

  .prose :global(.cta h3) {
    margin-top: 0;
  }

  .prose :global(.cta .button) {
    margin: 12px 0;
  }

  .prose :global(.poster) {
    width: 100%;
    max-width: 360px;
    margin: 16px auto 32px;
  }

  .prose :global(.poster img) {
    margin: 0;
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--tvc-line);
  }

  .prose :global(.poster figcaption) {
    margin-top: 8px;
    text-align: center;
    font-size: 0.82rem;
    color: var(--tvc-ink-soft);
  }
</style>
