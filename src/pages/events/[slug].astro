---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events', (e) => !e.data.draft);
  return events.map((event) => ({ params: { slug: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const formatDate = (d: Date) => d.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={event.data.title} description={event.data.excerpt} image={event.data.coverImage}>
  <PageHero eyebrow={formatDate(event.data.date)} title={event.data.title} image={event.data.coverImage} imageAlt={event.data.title} />
  <article class="section wrapper prose">
    <Content />
  </article>
</BaseLayout>

<style>
  .prose :global(h2) {
    margin-top: 32px;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--tvc-orange);
    padding-left: 20px;
    font-style: italic;
    color: var(--tvc-ink-soft);
  }

  .prose :global(img) {
    border-radius: var(--radius);
    margin: 16px 0;
  }

  .prose :global(table) {
    width: 100%;
    max-width: 72ch;
    border-collapse: collapse;
    margin: 16px 0 32px;
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 10px 16px;
    border-bottom: 1px solid var(--tvc-line);
  }

  .prose :global(th) {
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: var(--tvc-orange);
  }

  .prose :global(td:first-child) {
    color: var(--tvc-ink-soft);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .prose :global(.cta) {
    max-width: 72ch;
    margin: 32px 0;
  }

  .prose :global(.cta h3) {
    margin-top: 0;
  }

  .prose :global(.cta .button) {
    margin: 12px 0;
  }

  .prose :global(.poster) {
    width: 100%;
    max-width: 360px;
    margin: 16px auto 32px;
  }

  .prose :global(.poster img) {
    margin: 0;
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--tvc-line);
  }

  .prose :global(.poster figcaption) {
    margin-top: 8px;
    text-align: center;
    font-size: 0.82rem;
    color: var(--tvc-ink-soft);
  }
</style>
