---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const partners = await getCollection('partners');
---

<BaseLayout title="Partners" description="Organizations Tamarind Valley Collective partners with." image="/images/pages/history/hero.jpg" imageWidth={1536} imageHeight={922}>
  <PageHero eyebrow="Partners" title="Who we work with" image="/images/pages/history/hero.jpg" imageAlt="A thatched hut against the forested hillside" />
  <section class="section wrapper">
    <div class="grid">
      {partners.map((p) => (
        <a class="card" href={`/ecosystem/partners/${p.id}`}>
          {p.data.coverImage && <img src={p.data.coverImage} alt={p.data.title} loading="lazy" />}
          <h3>{p.data.title}</h3>
          <p>{p.data.excerpt}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }

  .grid a {
    text-decoration: none;
    color: inherit;
    text-align: center;
  }

  .grid img {
    width: 100px;
    height: 100px;
    object-fit: contain;
    margin: 0 auto 12px;
  }

  .grid p {
    font-size: 0.88rem;
    color: var(--tvc-ink-soft);
    margin: 8px 0 0;
  }
</style>
