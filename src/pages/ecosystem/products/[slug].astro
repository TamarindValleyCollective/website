---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({ params: { slug: product.id }, props: { product } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
---

<BaseLayout title={product.data.title} description={product.data.excerpt}>
  <PageHero eyebrow="Resource Centre" title={product.data.title} image={product.data.coverImage} imageAlt={product.data.title} />
  <article class="section wrapper prose">
    <Content />
  </article>
</BaseLayout>
