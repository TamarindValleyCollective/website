---

<BaseLayout title="In Pictures" description="Photos of Tamarind Valley Collective — the land, the community, and daily life at the farm, from 2017 to today." image="/images/pages/in-pictures/2017-02/0644E35B-70C7-4000-90E3-3EB64D924471.jpeg" imageWidth={768} imageHeight={574}>
  <PageHero eyebrow="About TVC" title="In Pictures" intro="Pictures are worth 10,000 words — an old proverb, and still true." image="/images/pages/in-pictures/2017-02/0644E35B-70C7-4000-90E3-3EB64D924471.jpeg" imageAlt="An early camping trip at the farm" />

  <section class="section wrapper">
    <div class="album-card">
      <div class="album-card__text">
        <p class="eyebrow">Community maintained</p>
        <h2>Want to see everything?</h2>
        <p>The archive below covers 2017 through 2020. The complete photo album is maintained by the community itself and updated with the latest photos from the farm — camps, workshops, wildlife, everyday life.</p>
        <a class="button" href="https://photos.app.goo.gl/DsTczqCzkqMBCDYM6" target="_blank" rel="noopener noreferrer">Open the full album →</a>
      </div>
    </div>
  </section>

  {archive.map((section, i) => (
    <section class:list={['section', { 'section--tint': i % 2 === 0 }]}>
      <div class="wrapper">
        <h2>{section.label}</h2>
        <div class="archive-grid">
          {section.photos.map((src) => (
            <a href={src} target="_blank" rel="noopener noreferrer">
              <img src={src} alt={`TVC, ${section.label}`} loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .album-card {
    background: var(--tvc-green-tint);
    border-radius: var(--radius);
    padding: 32px;
  }

  .album-card__text {
    max-width: 64ch;
  }

  .album-card h2 {
    margin-bottom: 10px;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 4px;
    margin-top: 16px;
  }

  .archive-grid a {
    display: block;
    overflow: hidden;
  }

  .archive-grid img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .archive-grid a:hover img {
    transform: scale(1.06);
  }

  @media (max-width: 640px) {
    .archive-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    }

    .archive-grid img {
      height: 100px;
    }
  }
</style>
