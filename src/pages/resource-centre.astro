---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Pending from '../components/Pending.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const outreach = await getCollection('communityOutreach');
---

<BaseLayout title="Resource Centre" description="Lantana furniture, farm produce, and learning programs from Tamarind Valley Collective.">
  <PageHero eyebrow="Resource Centre" title="Resource Centre" />

  <section class="section wrapper">
    <h2>Lantana Furniture</h2>
    <p>We support a local initiative creating useful items from Lantana — an invasive plant that has affected the growth of native vegetation.</p>
    <p>To place an order, contact <strong>Vivek Garady</strong> — <a href="mailto:Vivek.Garady@gmail.com">Vivek.Garady@gmail.com</a> · 94834 3037.</p>
    <a class="button button--outline" href="/files/lantana-furniture-catalogue.pdf" target="_blank" rel="noopener noreferrer">View the catalogue (PDF) →</a>
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <h2>Produce</h2>
      <div class="grid">
        {products.map((p) => (
          <a class="card" href={`/ecosystem/products/${p.id}`}>
            {p.data.coverImage && <img src={p.data.coverImage} alt={p.data.title} />}
            <h4>{p.data.title}</h4>
            <p>{p.data.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section wrapper">
    <h2>Learning programs</h2>
    <div class="grid">
      {outreach.map((o) => (
        <a class="card" href={`/community-outreach/${o.id}`}>
          {o.data.coverImage && <img src={o.data.coverImage} alt={o.data.title} />}
          <h4>{o.data.title}</h4>
          <p>{o.data.excerpt}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <h2>KANS</h2>
      <Pending note="The structure doc names 'KANS' here but no source material exists anywhere on the old site — confirm what it stands for and source or write this content." />
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }

  .grid a {
    text-decoration: none;
    color: inherit;
  }

  .grid img {
    border-radius: var(--radius) var(--radius) 0 0;
    margin: -24px -24px 16px;
    width: calc(100% + 48px);
    height: 140px;
    object-fit: cover;
  }
</style>
