---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Resource Centre" description="Lantana furniture and learning programs from Tamarind Valley Collective." image="/images/products/tamarind-chutney.jpeg" imageWidth={1280} imageHeight={960}>
  <PageHero eyebrow="Resource Centre" title="Resource Centre" image="/images/products/tamarind-chutney.jpeg" imageAlt="Jars of farm-made tamarind chutney" />

  <section class="section wrapper">
    <h2>Lantana Furniture</h2>
    <p>We support a local initiative creating useful items from Lantana — an invasive plant that has affected the growth of native vegetation.</p>
    <p>To place an order, contact <strong>Vivek Garady</strong> — <a href="mailto:Vivek.Garady@gmail.com">Vivek.Garady@gmail.com</a> · 94834 3037.</p>
    <a class="button button--outline" href="/files/lantana-furniture-catalogue.pdf" target="_blank" rel="noopener noreferrer">View the catalogue (PDF) →</a>
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <h2>Learning programs</h2>
      <p>Workshops and classes run with the local community — the full list lives on our <a href="/our-journey/community-outreach">Community Outreach</a> page.</p>
      <a class="button button--outline" href="/our-journey/community-outreach">See our learning programs →</a>
    </div>
  </section>
</BaseLayout>
