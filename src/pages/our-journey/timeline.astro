---
// Uses BaseLayout like every other page — Nav, Footer, ChatWidget, and the
// standard meta tags all come from there now. JourneyTimelineStandalone is
// a full-viewport-per-year scrolling experience by design (see its own
// header comment) — it renders in normal document flow, so the footer and
// chat widget stay reachable exactly as on every other page, just after a
// longer scroll.
import BaseLayout from '../../layouts/BaseLayout.astro';
import JourneyTimeline from '../../components/JourneyTimelineStandalone.astro';
---

<BaseLayout title="Our Journey So Far" description="From a degraded 100-acre farm to a regenerating ecosystem — year by year." image="/images/pages/journey/hero.jpg" imageWidth={1280} imageHeight={960}>
  <JourneyTimeline />
</BaseLayout>
