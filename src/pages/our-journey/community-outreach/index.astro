---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('communityOutreach');
---

<BaseLayout title="Community Outreach" description="Work TVC has done with the local community around the farm, in Odhipuram and Thaggatti village." image="/images/community-outreach/stem-experiential-learning-classes.jpeg" imageWidth={1280} imageHeight={960}>
  <PageHero eyebrow="Our Journey" title="Community Outreach" intro="Work with the local community around the farm, in Odhipuram and Thaggatti village." image="/images/community-outreach/stem-experiential-learning-classes.jpeg" imageAlt="A STEM class in session at the local village school" />
  <section class="section wrapper">
    <div class="grid">
      {posts.map((p) => (
        <a class="card" href={`/our-journey/community-outreach/${p.id}`}>
          {p.data.coverImage && <img src={p.data.coverImage} alt={p.data.title} loading="lazy" />}
          <h3>{p.data.title}</h3>
          <p>{p.data.excerpt}</p>
        </a>
      ))}
    </div>
    <p class="cta-line">Want to work with the community on an initiative aligned with the farm's ethos? <a href="/contact">Reach out</a>.</p>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .grid a {
    text-decoration: none;
    color: inherit;
  }

  .grid img {
    border-radius: var(--radius) var(--radius) 0 0;
    margin: -24px -24px 16px;
    width: calc(100% + 48px);
    height: 160px;
    object-fit: cover;
  }

  .cta-line {
    margin-top: 20px;
  }
</style>
