---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BiodiversityExplorer from '../components/biodiversity/BiodiversityExplorer.astro';
---

<BaseLayout title="Biodiversity" description="Live biodiversity sightings and birds at Tamarind Valley Collective." image="/images/pages/trekking/watering-hole.jpg" imageWidth={1384} imageHeight={1038}>
  <PageHero eyebrow="The TVC Ecosystem" title="What lives here" intro="From over 100 bird species in the food forest itself — explore live sightings below, filed alongside everything else we know about the farm's ecosystem." image="/images/pages/trekking/watering-hole.jpg" imageAlt="A forest watering hole near the farm, where wildlife comes to drink" />

  <section class="section wrapper">
    <BiodiversityExplorer />
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <a class="card geography-card" href="/ecosystem/geography">
        <h3>Geography &amp; Weather</h3>
        <p>The land TVC sits on, and the rainfall and monsoon patterns that shape it — including live-updated monthly rainfall.</p>
        <span class="geography-card__link">See geography &amp; weather →</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .geography-card {
    display: block;
    max-width: 480px;
    text-decoration: none;
  }

  .geography-card h3 {
    margin-bottom: 8px;
  }

  .geography-card p {
    color: var(--tvc-ink-soft);
    margin: 0 0 14px;
  }

  .geography-card__link {
    font-weight: 600;
    color: var(--tvc-green-dark);
  }
</style>
