---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Pending from '../components/Pending.astro';
import BiodiversityExplorer from '../components/biodiversity/BiodiversityExplorer.astro';
---

<BaseLayout title="The TVC Ecosystem" description="Live biodiversity sightings, birds, trees, geography, and weather at Tamarind Valley Collective.">
  <PageHero eyebrow="The TVC Ecosystem" title="What lives here" intro="From over 100 bird species to the food forest itself — explore live sightings below, filed alongside everything else we know about the farm's ecosystem." />

  <section class="section wrapper">
    <BiodiversityExplorer />
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <h2>Snakes</h2>
      <Pending note="No content existed on the old site for this — genuinely new to write." />
    </div>
  </section>

  <section class="section wrapper">
    <h2>Trees &amp; Plants</h2>
    <Pending note="No dedicated old-site page — what exists is scattered across other pages (the food forest, land design). Worth consolidating into its own page here, and cross-referencing the Plants entries in the explorer above." />
  </section>

  <section class="section section--tint">
    <div class="wrapper">
      <h2>Geography, landscape &amp; weather</h2>
      <Pending note="The old site's 'Soil and Weather Conditions' page was never filled in beyond the page shell — rainfall and temperature data still need to be written up." />
    </div>
  </section>
</BaseLayout>
