---
// Standalone, single-viewport page: intentionally skips BaseLayout's
// Footer so the whole experience fits one screen with no page scroll.
// Only the month carousel inside JourneyTimelineStandalone scrolls internally.
// Named "Standalone" to avoid colliding with the separate JourneyTimeline.astro
// used on /our-journey.
import Nav from '../components/Nav.astro';
import JourneyTimeline from '../components/JourneyTimelineStandalone.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="From a degraded 100-acre farm to a regenerating ecosystem — year by year." />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Our Journey, Year by Year · Tamarind Valley Collective</title>
  </head>
  <body class="tl-page-body">
    <Nav />
    <main class="tl-page-main">
      <JourneyTimeline />
    </main>
  </body>
</html>

<style>
  .tl-page-body {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #f6f1e7;
  }

  .tl-page-main {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  /* .tl-root is JourneyTimelineStandalone's own root element — it lives
     across the component boundary, so it needs :global() to be reached
     from here. Without flex-grow it would size to content instead of
     filling .tl-page-main, leaving a blank gap below it on short viewports. */
  .tl-page-main :global(.tl-root) {
    flex: 1 1 auto;
    min-height: 0;
  }

  @media (max-width: 760px) {
    .tl-page-body {
      height: auto;
      min-height: 100dvh;
      overflow: visible;
    }
  }
</style>
