---
// Uses BaseLayout like every other page — Nav, Footer, ChatWidget, and the
// standard meta tags all come from there now. The interactive timeline
// itself stays visually "contained" (most of the viewport, not a long
// scroll through every card) via a bounded-height wrapper below, rather
// than literally locking the whole page to 100dvh — that made the page
// diverge from the rest of the site (no footer ever reachable, no chat
// widget). A little natural scroll to reach the footer is how every other
// page here behaves.
import BaseLayout from '../layouts/BaseLayout.astro';
import JourneyTimeline from '../components/JourneyTimelineStandalone.astro';
---

<BaseLayout title="Our Journey So Far" description="From a degraded 100-acre farm to a regenerating ecosystem — year by year." image="/images/pages/journey/hero.jpg" imageWidth={1280} imageHeight={960}>
  <div class="timeline-page">
    <JourneyTimeline />
  </div>
</BaseLayout>

<style>
  .timeline-page {
    height: 82vh;
    min-height: 600px;
    max-height: 900px;
    display: flex;
    flex-direction: column;
    background: var(--tvc-cream);
  }

  /* .tl-root is JourneyTimelineStandalone's own root element — it lives
     across the component boundary, so it needs :global() to be reached
     from here. Without flex-grow it would size to content instead of
     filling .timeline-page, leaving a blank gap below it on short viewports. */
  .timeline-page :global(.tl-root) {
    flex: 1 1 auto;
    min-height: 0;
  }

  @media (max-width: 760px) {
    .timeline-page {
      height: auto;
      min-height: 640px;
      max-height: none;
    }
  }
</style>
