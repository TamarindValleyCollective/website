---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with Tamarind Valley Collective — phone, location, and social media.">
  <PageHero eyebrow="Contact Us" title="Get in touch" />

  <section class="section wrapper contact-grid">
    <div>
      <h3>Phone</h3>
      <p>Madhav — <a href="tel:+917406307309">+91 74063 07309</a></p>

      <h3>Address</h3>
      <p>Tamarind Valley Collective<br />Thaggatti village, near Kanakapura<br />Karnataka/Tamil Nadu border, India</p>

      <h3>Social</h3>
      <p>
        <a href="https://www.facebook.com/farm.tvc" target="_blank" rel="noopener noreferrer">Facebook</a> ·
        <a href="https://twitter.com/TVCFarm" target="_blank" rel="noopener noreferrer">Twitter</a> ·
        <a href="https://www.instagram.com/tamarindvalleycollective/" target="_blank" rel="noopener noreferrer">Instagram</a>
      </p>

      <h3>Location</h3>
      <div class="map-embed">
        <iframe
          loading="lazy"
          src="https://www.google.com/maps/d/u/0/embed?mid=1b_d-2ZOwDBRTJjbDZ2ovJ7QsdPiqnYrA"
          width="100%"
          height="360"
          style="border:0"
          title="Map to Tamarind Valley Collective"
        ></iframe>
      </div>
    </div>

    <div class="card">
      <h3>Join Friends of TVC</h3>
      <p>Share your name and phone number and we'll add you to the Friends of TVC WhatsApp group — occasional updates on events, volunteering, and life at the farm.</p>
      <form
        class="signup-form"
        name="friends-of-tvc"
        method="POST"
        action="/contact/thanks"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="friends-of-tvc" />
        <p class="signup-hp"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <label for="name">Name</label>
        <input id="name" type="text" name="name" placeholder="Your name" autocomplete="name" required />
        <label for="phone">Phone number</label>
        <input id="phone" type="tel" name="phone" placeholder="+91 98765 43210" autocomplete="tel" required />
        <button class="button" type="submit">Join the group</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 32px;
  }

  .contact-grid h3 {
    margin-top: 24px;
  }

  .contact-grid h3:first-child {
    margin-top: 0;
  }

  .map-embed iframe {
    border-radius: var(--radius);
  }

  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }

  .signup-form input {
    padding: 10px 14px;
    border: 1px solid var(--tvc-line);
    border-radius: 999px;
  }

  /* Netlify Forms spam honeypot — off-screen, not display:none (some bots
     skip hidden fields, but few check for visibility via position). */
  .signup-hp {
    position: absolute;
    left: -9999px;
  }

  @media (max-width: 780px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
