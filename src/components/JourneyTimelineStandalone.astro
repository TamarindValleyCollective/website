---
// Faithful port of tvc_timeline.html into an Astro component. Kept as
// close to the original markup/CSS/JS as possible (same class/id names,
// prefixed with "tl-" to avoid clashing with the rest of the site, and
// wrapped in .tl-root so the color variables — declared once there —
// reach both the inline app and the modal overlay, which is a sibling
// of .tl-app, not a descendant of it, since it's position:fixed).
//
// Structured around "eras" so this scales past a single flat year row:
// each era owns its own poem + year timeline. With exactly one era (today),
// the era-picker never renders and the single era's panel shows directly —
// pixel-identical to a flat single-row timeline. The moment a second era
// gets real years, the picker appears automatically and eras become
// selectable chapters instead of one ever-lengthening row.
interface MonthEntry {
  m: string;
  t: string;
  imgs: string[];
  // Per-image captions, same length as imgs — shown in place of the
  // month's single `t` as the photo carousel is swiped. Omit to just
  // repeat `t` for every photo (the default when one caption covers
  // the whole month's single event).
  imgCaptions?: string[];
  // Per-image object-fit override, same length as imgs. Real farm
  // photography looks best cropped to fill the frame ('cover', the
  // default); flat graphics like the logo need 'contain' so nothing
  // gets cropped off.
  imgFit?: ('cover' | 'contain')[];
}

interface YearEntry {
  year: number;
  icon: string;
  summary: string;
  intro: string;
  months: MonthEntry[];
}

interface Era {
  key: string;
  name: string;
  range: string;
  // Poem stanzas for this era's landing view. Each string is one stanza;
  // internal line breaks are literal "\n" and rendered via CSS
  // white-space: pre-line rather than embedded <br/> markup.
  poem: string[];
  years: YearEntry[];
}

// Consistent monoline SVG icons (24x24 viewBox, single stroke weight) instead
// of raw emoji — different emoji glyphs render at wildly different visual
// sizes/baselines even at the same font-size, which is why the dots looked
// misaligned; a shared icon style guarantees they line up.
const ICONS: Record<number, string> = {
  2017: `<svg viewBox="0 0 24 24"><path d="M12 21V10"/><path d="M12 10c0-4.2-3.1-6.4-7.2-6.4 0 4.2 3.1 7.4 7.2 6.4z"/><path d="M12 10c0-4.2 3.1-6.4 7.2-6.4 0 4.2-3.1 7.4-7.2 6.4z"/></svg>`,
  2018: `<svg viewBox="0 0 24 24"><path d="M3.5 20h17"/><path d="M5 20 12 6l7 14"/><path d="M9.5 20v-5.5h5V20"/></svg>`,
  2019: `<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8.3"/><path d="M15.2 8.8l-2.1 5.6-5.6 2 2.1-5.6 5.6-2z"/></svg>`,
  2020: `<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2.3v3M12 18.7v3M4.3 4.3l2.1 2.1M17.6 17.6l2.1 2.1M2.3 12h3M18.7 12h3M4.3 19.7l2.1-2.1M17.6 6.4l2.1-2.1"/></svg>`,
  2021: `<svg viewBox="0 0 24 24"><path d="M12 4v9"/><line x1="4.5" y1="13" x2="19.5" y2="13"/><path d="M12 13c-1.2 3.2-3.2 4.3-5.4 8.5M12 13c1.2 3.2 3.2 4.3 5.4 8.5M12 13v8.5"/></svg>`,
  2022: `<svg viewBox="0 0 24 24"><path d="M6 20V9.5L12 5l6 4.5V20"/><path d="M10 20v-6h4v6"/></svg>`,
  2023: `<svg viewBox="0 0 24 24"><path d="M13 2 4.5 13.5h5.8L9 21.5l9.5-12.6h-5.8L13 2z"/></svg>`,
  2024: `<svg viewBox="0 0 24 24"><path d="M4 20h16"/><path d="M4.5 20v-4h15v4"/><path d="M7.5 16v-3M12 16v-3M16.5 16v-3"/></svg>`,
  2025: `<svg viewBox="0 0 24 24"><path d="M12 2.2c1.1 3.8-2.6 5-2.6 8.6a2.6 2.6 0 005.2 0c0-1.3-.9-1.8-.9-3.1 1.8 1 2.7 3.2 2.7 5a4.4 4.4 0 01-8.8 0c0-4.6 3.5-5.6 4.4-10.5z"/></svg>`,
  2026: `<svg viewBox="0 0 24 24"><path d="M4 11 12 4l8 7"/><path d="M6 10.2v10.3h5v-6h2v6h5V10.2"/></svg>`,
};

