  .tl-modal {
    background: var(--tl-white, #fffdf9);
    /* Previously capped at a flat 640x640 regardless of viewport, which
       left it looking small and boxed-in on large desktop screens. Scaling
       with clamp() lets it grow with the window (up to a sensible max, so
       it doesn't sprawl absurdly wide on ultrawide monitors) while the
       640px floor keeps it exactly as it was on small windows. */
    width: clamp(min(640px, 100%), 55vw, 960px);
    height: clamp(min(600px, 86vh, 86dvh), 80vh, 840px);
    border-radius: 18px;
    display: flex;
    flex-direction: column;
