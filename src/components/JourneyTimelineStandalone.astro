const ERAS: Era[] = [
  {
    key: 'founding',
    name: 'Founding',
    range: '2017–2026',
    poem: [
      'Nine years back, ten hands and a fence line\nheld a barren field near Thakkatti behind.\nEarthwork by earthwork, one workshop, one season —\nthe soil slowly remembered its reason.',
      'A mud hut rose by hand. A wildfire came and went.\nElephants wandered through, uninvited, unbent.\nA transformer vanished one restless July night —\nstill, somehow, the years kept turning out right.',
      'Nine winters deep in, our first true home now stands.\nTap a year below — and walk it through, hand in hand.',
    ],
    years: FOUNDING_YEARS,
  },
  // The next era (e.g. "Growth", 2027–2036) gets appended here once it has
  // real years/content. The moment ERAS.length > 1, the era-picker below
  // renders automatically and each era becomes its own selectable chapter
  // instead of one ever-lengthening row of dots.
];

// Swap each year's placeholder emoji for its consistent SVG icon (looked up
// by year) so both the template below and the client script — which only
// receives ERAS via define:vars, not this module-scope ICONS map — render
// the same markup.
ERAS.forEach((era) => {
  era.years.forEach((y) => {
    y.icon = ICONS[y.year];
  });
});
---

<div class="tl-root">
  <div class="tl-app" id="tl-app">
    <header class="tl-app-header">
      <h1>Our Journey So Far</h1>
    </header>

    {ERAS.length > 1 && (
      <div class="tl-era-picker" id="tl-era-picker">
        {ERAS.map((era, ei) => (
          <button type="button" class="tl-era-card" data-era={ei}>
            <h2>{era.name}</h2>
            <p>{era.range}</p>
          </button>
        ))}
      </div>
    )}

    {ERAS.map((era, ei) => (
      <div class="tl-era-panel" data-era-panel={ei} hidden={ERAS.length > 1}>
        {ERAS.length > 1 && (
          <button type="button" class="tl-era-back" data-era-back>← All eras</button>
        )}
        <div class="tl-app-poem">
          {era.poem.map((stanza) => <p>{stanza}</p>)}
        </div>
        <div class="tl-connector" aria-hidden="true">
          <span class="tl-connector-line"></span>
          <span class="tl-connector-icon">🌱</span>
          <span class="tl-connector-line"></span>
        </div>
        <p class="tl-invite" aria-hidden="true">↓ tap a year to begin ↓</p>
        <div class="tl-stage">
          <div class="tl-timeline-scroll">
            <div class="tl-timeline">
              {era.years.map((y, i) => (
                <button type="button" class="tl-year-node" data-era={ei} data-index={i} style={`--tl-pulse-delay: ${i * 0.18}s`}>
                  <div class="tl-dot"><span class="tl-dot-ring"></span><span class="tl-dot-icon" set:html={y.icon} /></div>
                  <div class="tl-yr">{y.year}</div>
                  <div class="tl-lbl">{y.summary}</div>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}

    <div class="tl-hint">← scroll or swipe to see all years →</div>
  </div>

  <div class="tl-overlay" id="tl-overlay">
    <div class="tl-modal" id="tl-modal" role="dialog" aria-modal="true">
      <div class="tl-modal-head">
        <div class="tl-m-icon" id="tl-m-icon"></div>
        <div class="tl-m-titles">
          <div class="tl-m-year" id="tl-m-year"></div>
          <div class="tl-m-month" id="tl-m-month"></div>
        </div>
        <div class="tl-modal-nav">
          <button type="button" class="tl-nav-btn" id="tl-prev-year" aria-label="Previous year">‹</button>
          <button type="button" class="tl-nav-btn" id="tl-next-year" aria-label="Next year">›</button>
          <button type="button" class="tl-close-btn" id="tl-close-btn" aria-label="Close">✕</button>
        </div>
      </div>
      <div class="tl-modal-body">
        <div class="tl-track-wrap" id="tl-track-wrap">
          <div class="tl-month-track" id="tl-month-track"></div>
          <div class="tl-car-arrows tl-month-arrows" id="tl-month-arrows">
            <button type="button" id="tl-month-prev" aria-label="Previous month">‹</button>
            <button type="button" id="tl-month-next" aria-label="Next month">›</button>
          </div>
        </div>
      </div>
      <div class="tl-modal-foot">
        <div class="tl-car-dots" id="tl-month-dots"></div>
        <span class="tl-foot-lbl" id="tl-foot-label"></span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ ERAS }}>
  let activeEra = 0;
  let activeYearIndex = -1;
  let currentSlides = [];

  const root = document.querySelector('.tl-root');
  const overlay = root.querySelector('#tl-overlay');
  const monthTrack = root.querySelector('#tl-month-track');
  const monthDots = root.querySelector('#tl-month-dots');
  const footLabel = root.querySelector('#tl-foot-label');
  const mIcon = root.querySelector('#tl-m-icon');
  const mYear = root.querySelector('#tl-m-year');
  const mMonth = root.querySelector('#tl-m-month');
  const prevYearBtn = root.querySelector('#tl-prev-year');
  const nextYearBtn = root.querySelector('#tl-next-year');
  const monthPrevBtn = root.querySelector('#tl-month-prev');
  const monthNextBtn = root.querySelector('#tl-month-next');
  const eraPicker = root.querySelector('#tl-era-picker');
  const eraPanels = Array.from(root.querySelectorAll('.tl-era-panel'));

  // One slide per photo (not per month) — a month with several photos used
  // to nest its own inner carousel inside the outer month-by-month track,
  // which meant two independent horizontal scrollers stacked on each other.
  // Flattening every photo into its own slide on the single outer track
  // gives one continuous, unambiguous swipe gesture for the whole year.
  function buildSlides(y) {
    const slides = [];
    if (y.intro) slides.push({ label: 'Overview', year: y.year, text: y.intro, img: null });
    y.months.forEach((mo) => {
      const imgs = mo.imgs || [];
      if (imgs.length === 0) {
        slides.push({ label: mo.m, year: y.year, text: mo.t, img: null });
        return;
      }
      const captions = (mo.imgCaptions && mo.imgCaptions.length === imgs.length) ? mo.imgCaptions : null;
      imgs.forEach((src, idx) => {
        slides.push({
          label: mo.m,
          year: y.year,
          text: captions ? captions[idx] : mo.t,
          img: src,
          fit: (mo.imgFit && mo.imgFit[idx]) || 'cover',
        });
      });
    });
    return slides;
  }

  function renderSlide(slide) {
    if (!slide.img) {
      return `<div class="tl-month-slide tl-no-img"><p class="tl-caption-standalone">${slide.text}</p></div>`;
    }
    const fitStyle = slide.fit === 'contain' ? 'object-fit:contain;background:var(--tl-sand-2);' : 'object-fit:cover;';
    return `<div class="tl-month-slide">
      <div class="tl-slide-media">
        <img loading="lazy" src="${slide.img}" alt="${slide.label} photo" style="${fitStyle}">
        <div class="tl-slide-caption"><p>${slide.text}</p></div>
      </div>
    </div>`;
  }

  // Briefly highlights an element when the text it just received differs
  // from what it showed before — a quick fade/slide-in "pop" so a month or
  // year change registers even when the user's eyes are on the photo, not
  // the header. Restarting a CSS animation requires a reflow in between
  // removing and re-adding the class, otherwise the browser no-ops it.
  function flashHeader(el) {
    el.classList.remove('tl-flash');
    void el.offsetWidth;
    el.classList.add('tl-flash');
  }

  function updateMonthUI() {
    const w = monthTrack.clientWidth || 1;
    const i = Math.max(0, Math.min(currentSlides.length - 1, Math.round(monthTrack.scrollLeft / w)));
    monthDots.querySelectorAll('span').forEach((d, idx) => d.classList.toggle('on', idx === i));

    const slide = currentSlides[i];
    const monthLabel = slide ? slide.label : '';
    const yearLabel = slide ? String(slide.year) : '';
    if (monthLabel && monthLabel !== mMonth.textContent) {
      mMonth.textContent = monthLabel;
      flashHeader(mMonth);
    }
    if (yearLabel && yearLabel !== mYear.textContent) {
      mYear.textContent = yearLabel;
      flashHeader(mYear);
    }

    footLabel.textContent = `${i + 1} / ${currentSlides.length}`;
    // Only disable at a true dead end (first month of the first year, or
    // last month of the last year) — otherwise stepMonth() should be able
    // to carry the button click across into the next/previous year, and a
    // disabled button never fires a click at all.
    monthPrevBtn.disabled = i === 0 && activeYearIndex === 0;
    monthNextBtn.disabled = i === currentSlides.length - 1 && activeYearIndex === ERAS[activeEra].years.length - 1;
  }

  function goToMonth(i) {
    i = Math.max(0, Math.min(currentSlides.length - 1, i));
    monthTrack.scrollTo({ left: monthTrack.clientWidth * i, behavior: 'smooth' });
  }

  function openYear(eraIdx, i, atEnd) {
    activeEra = eraIdx;
    activeYearIndex = i;
    const y = ERAS[eraIdx].years[i];
    root.classList.add('engaged');
    root.querySelectorAll('.tl-year-node').forEach((n) => n.classList.remove('active'));
    root.querySelector(`.tl-year-node[data-era="${eraIdx}"][data-index="${i}"]`).classList.add('active');

    mIcon.innerHTML = y.icon;
    mYear.textContent = y.year;
    flashHeader(mYear);

    currentSlides = buildSlides(y);
    monthTrack.innerHTML = currentSlides.map(renderSlide).join('');

    const landingSlide = atEnd ? currentSlides[currentSlides.length - 1] : currentSlides[0];
    mMonth.textContent = landingSlide ? landingSlide.label : '';
    flashHeader(mMonth);

    monthDots.innerHTML = currentSlides.map((_, idx) => `<span class="${idx === 0 ? 'on' : ''}"></span>`).join('');

    prevYearBtn.disabled = i === 0;
    nextYearBtn.disabled = i === ERAS[eraIdx].years.length - 1;

    overlay.classList.add('open');

    // Landing on a year via "slide past the edge into the previous year"
    // should drop you on its LAST month, so continuing to swipe backward
    // reads as one continuous motion rather than restarting from January.
    requestAnimationFrame(() => {
      const targetIndex = atEnd ? currentSlides.length - 1 : 0;
      monthTrack.scrollTo({ left: monthTrack.clientWidth * targetIndex, behavior: 'auto' });
      updateMonthUI();
    });

    const activeNode = root.querySelector(`.tl-year-node[data-era="${eraIdx}"][data-index="${i}"]`);
    activeNode.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
  }

  // Shared by the month arrow buttons, the keyboard, and touch-swipe: step
  // one month in `delta`'s direction, but if that would go past the first
  // or last month of the current year, cross into the adjacent year instead
  // (landing on its last month when stepping backward) — so browsing feels
  // like one continuous timeline instead of a wall you hit at each year's
  // edge and have to close the modal to get past.
  function stepMonth(delta) {
    const w = monthTrack.clientWidth || 1;
    const i = Math.round(monthTrack.scrollLeft / w);
    const next = i + delta;
    if (next < 0) {
      if (activeYearIndex > 0) openYear(activeEra, activeYearIndex - 1, true);
    } else if (next > currentSlides.length - 1) {
      if (activeYearIndex < ERAS[activeEra].years.length - 1) openYear(activeEra, activeYearIndex + 1, false);
    } else {
      goToMonth(next);
    }
  }

  function closeModal() {
    overlay.classList.remove('open');
    root.querySelectorAll('.tl-year-node').forEach((n) => n.classList.remove('active'));
    activeYearIndex = -1;
  }

  root.querySelectorAll('.tl-year-node').forEach((node) => {
    node.addEventListener('click', () => openYear(Number(node.dataset.era), Number(node.dataset.index)));
  });

  monthTrack.addEventListener('scroll', () => {
    window.clearTimeout(monthTrack._t);
    monthTrack._t = window.setTimeout(updateMonthUI, 60);
  });
  monthPrevBtn.addEventListener('click', () => stepMonth(-1));
  monthNextBtn.addEventListener('click', () => stepMonth(1));

  // Touch swipe past the first/last month crosses into the adjacent year.
  // Only fires at the boundary slide and only for a deliberate over-swipe
  // (past a distance threshold) in the direction that would otherwise do
  // nothing, so it doesn't interfere with normal swiping between months.
  let monthTouchStartX = 0;
  monthTrack.addEventListener('touchstart', (e) => {
    monthTouchStartX = e.touches[0].clientX;
  }, { passive: true });
  monthTrack.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - monthTouchStartX;
    const w = monthTrack.clientWidth || 1;
    const i = Math.round(monthTrack.scrollLeft / w);
    const threshold = 40;
    if (i === 0 && dx > threshold) {
      if (activeYearIndex > 0) openYear(activeEra, activeYearIndex - 1, true);
    } else if (i === currentSlides.length - 1 && dx < -threshold) {
      if (activeYearIndex < ERAS[activeEra].years.length - 1) openYear(activeEra, activeYearIndex + 1, false);
    }
  }, { passive: true });

  root.querySelector('#tl-close-btn').addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  prevYearBtn.addEventListener('click', () => { if (activeYearIndex > 0) openYear(activeEra, activeYearIndex - 1); });
  nextYearBtn.addEventListener('click', () => { if (activeYearIndex < ERAS[activeEra].years.length - 1) openYear(activeEra, activeYearIndex + 1); });

  document.addEventListener('keydown', (e) => {
    if (!overlay.classList.contains('open')) return;
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowRight') stepMonth(1);
    if (e.key === 'ArrowLeft') stepMonth(-1);
  });

  window.addEventListener('resize', () => {
    if (overlay.classList.contains('open')) {
      const w = monthTrack.clientWidth || 1;
      const i = Math.round(monthTrack.scrollLeft / w);
      monthTrack.scrollTo({ left: w * i, behavior: 'auto' });
    }
  });

  // Era picker: only present in the DOM when there's more than one era with
  // content (see the ERAS.length > 1 guards in the template above).
  eraPicker?.querySelectorAll('.tl-era-card').forEach((card) => {
    card.addEventListener('click', () => {
      const ei = Number(card.dataset.era);
      eraPicker.hidden = true;
      eraPanels.forEach((p) => { p.hidden = Number(p.dataset.eraPanel) !== ei; });
    });
  });
  root.querySelectorAll('[data-era-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      eraPanels.forEach((p) => { p.hidden = true; });
      if (eraPicker) eraPicker.hidden = false;
    });
  });
</script>

