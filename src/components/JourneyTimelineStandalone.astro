---

<div class="tl-root">
  <div class="tl-app" id="tl-app">
    <header class="tl-app-header">
      <h1>TVC — Our Journey</h1>
      <p>Tap a year to explore the story, month by month</p>
    </header>
    <p class="tl-app-summary">Nine years ago, ten founders fenced off a barren, overgrazed plot near Thakkatti village and started regenerating it — one earthwork, one workshop, one hard-won season at a time. Along the way: a mud hut built by hand, a wildfire, a couple of elephant visits, a stolen transformer, and — this year — our very first completed home. Tap any year below to relive it, month by month.</p>
    <div class="tl-stage" id="tl-stage">
      <div class="tl-timeline-scroll" id="tl-timeline-scroll">
        <div class="tl-timeline" id="tl-timeline">
          {YEARS.map((y, i) => (
            <button type="button" class="tl-year-node" data-index={i}>
              <div class="tl-dot">{y.icon}</div>
              <div class="tl-yr">{y.year}</div>
              <div class="tl-lbl">{y.summary}</div>
            </button>
          ))}
        </div>
      </div>
    </div>
    <div class="tl-hint">← scroll or swipe to see all years →</div>
  </div>

  <div class="tl-overlay" id="tl-overlay">
    <div class="tl-modal" id="tl-modal" role="dialog" aria-modal="true">
      <div class="tl-modal-head">
        <div class="tl-m-icon" id="tl-m-icon"></div>
        <div class="tl-m-titles">
          <div class="tl-m-year" id="tl-m-year"></div>
          <div class="tl-m-summary" id="tl-m-summary"></div>
        </div>
        <button type="button" class="tl-nav-btn" id="tl-prev-year" aria-label="Previous year">‹</button>
        <button type="button" class="tl-nav-btn" id="tl-next-year" aria-label="Next year">›</button>
        <button type="button" class="tl-close-btn" id="tl-close-btn" aria-label="Close">✕</button>
      </div>
      <div class="tl-modal-body">
        <div class="tl-track-wrap" id="tl-track-wrap">
          <div class="tl-month-track" id="tl-month-track"></div>
          <div class="tl-car-arrows tl-month-arrows" id="tl-month-arrows">
            <button type="button" id="tl-month-prev" aria-label="Previous month">‹</button>
            <button type="button" id="tl-month-next" aria-label="Next month">›</button>
          </div>
        </div>
      </div>
      <div class="tl-modal-foot">
        <div class="tl-car-dots" id="tl-month-dots"></div>
        <span class="tl-foot-lbl" id="tl-foot-label"></span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ YEARS }}>
  let activeYearIndex = -1;
  let currentSlides = [];

  const root = document.querySelector('.tl-root');
  const timelineEl = root.querySelector('#tl-timeline');
  const overlay = root.querySelector('#tl-overlay');
  const monthTrack = root.querySelector('#tl-month-track');
  const monthDots = root.querySelector('#tl-month-dots');
  const footLabel = root.querySelector('#tl-foot-label');
  const mIcon = root.querySelector('#tl-m-icon');
  const mYear = root.querySelector('#tl-m-year');
  const mSummary = root.querySelector('#tl-m-summary');
  const prevYearBtn = root.querySelector('#tl-prev-year');
  const nextYearBtn = root.querySelector('#tl-next-year');
  const monthPrevBtn = root.querySelector('#tl-month-prev');
  const monthNextBtn = root.querySelector('#tl-month-next');

  function buildSlides(y) {
    const slides = [];
    if (y.intro) slides.push({ label: 'Overview', text: y.intro, imgs: [] });
    y.months.forEach((mo) => slides.push({ label: mo.m, text: mo.t, imgs: mo.imgs || [], imgCaptions: mo.imgCaptions, imgFit: mo.imgFit }));
    return slides;
  }

  function renderPhotoCarousel(imgs, label, imgFit) {
    const fitFor = (idx) => (imgFit && imgFit[idx]) || 'cover';
    const imgStyle = (idx) => {
      const fit = fitFor(idx);
      return `object-fit:${fit};${fit === 'contain' ? 'background:var(--tl-sand-2);' : ''}`;
    };
    if (imgs.length === 1) {
      return `<div class="tl-carousel"><div class="tl-car-track"><img loading="lazy" src="${imgs[0]}" alt="${label} photo" style="${imgStyle(0)}"></div></div>`;
    }
    const imgsHtml = imgs.map((src, idx) => `<img loading="lazy" src="${src}" alt="${label} photo" style="${imgStyle(idx)}">`).join('');
    const dotsHtml = imgs.map((_, idx) => `<span class="${idx === 0 ? 'on' : ''}"></span>`).join('');
    return `<div class="tl-carousel">
      <div class="tl-car-track">${imgsHtml}</div>
      <div class="tl-car-arrows"><button class="tl-c-prev" aria-label="Previous photo">‹</button><button class="tl-c-next" aria-label="Next photo">›</button></div>
      <div class="tl-car-dots">${dotsHtml}</div>
    </div>`;
  }

  function captionsFor(slide) {
    if (slide.imgCaptions && slide.imgCaptions.length === slide.imgs.length) return slide.imgCaptions;
    return slide.imgs.length > 0 ? slide.imgs.map(() => slide.text) : [slide.text];
  }

  function renderSlide(slide) {
    const hasImgs = slide.imgs && slide.imgs.length > 0;
    const captions = captionsFor(slide);
    return `<div class="tl-month-slide ${hasImgs ? '' : 'tl-no-img'}" data-captions="${encodeURIComponent(JSON.stringify(captions))}">
      <h3>${slide.label}</h3>
      <p class="tl-caption-text">${captions[0]}</p>
      ${hasImgs ? `<div class="tl-car-wrap">${renderPhotoCarousel(slide.imgs, slide.label, slide.imgFit)}</div>` : ''}
    </div>`;
  }

  function wirePhotoCarousels(container) {
    container.querySelectorAll('.tl-carousel').forEach((car) => {
      const track = car.querySelector('.tl-car-track');
      const dots = car.querySelectorAll('.tl-car-dots span');
      const prev = car.querySelector('.tl-c-prev');
      const next = car.querySelector('.tl-c-next');
      const slideEl = car.closest('.tl-month-slide');
      const captionEl = slideEl ? slideEl.querySelector('.tl-caption-text') : null;
      let captions = [];
      try { captions = JSON.parse(decodeURIComponent(slideEl?.dataset.captions || '%5B%5D')); } catch (e) { captions = []; }
      function updateCaption(i) {
        if (captionEl && captions[i] !== undefined) captionEl.textContent = captions[i];
      }
      if (!track || track.children.length < 2) return;
      function scrollToIndex(i) {
        track.scrollTo({ left: track.clientWidth * i, behavior: 'smooth' });
      }
      prev && prev.addEventListener('click', (e) => {
        e.stopPropagation();
        const i = Math.round(track.scrollLeft / track.clientWidth);
        scrollToIndex(Math.max(0, i - 1));
      });
      next && next.addEventListener('click', (e) => {
        e.stopPropagation();
        const i = Math.round(track.scrollLeft / track.clientWidth);
        scrollToIndex(Math.min(track.children.length - 1, i + 1));
      });
      track.addEventListener('scroll', () => {
        const i = Math.round(track.scrollLeft / track.clientWidth);
        dots.forEach((d, idx) => d.classList.toggle('on', idx === i));
        updateCaption(i);
      });
    });
  }

  function updateMonthUI() {
    const w = monthTrack.clientWidth || 1;
    const i = Math.max(0, Math.min(currentSlides.length - 1, Math.round(monthTrack.scrollLeft / w)));
    monthDots.querySelectorAll('span').forEach((d, idx) => d.classList.toggle('on', idx === i));
    footLabel.textContent = `${currentSlides[i] ? currentSlides[i].label : ''} · ${i + 1}/${currentSlides.length}`;
    monthPrevBtn.disabled = i === 0;
    monthNextBtn.disabled = i === currentSlides.length - 1;
  }

  function goToMonth(i) {
    i = Math.max(0, Math.min(currentSlides.length - 1, i));
    monthTrack.scrollTo({ left: monthTrack.clientWidth * i, behavior: 'smooth' });
  }

  function openYear(i) {
    activeYearIndex = i;
    const y = YEARS[i];
    root.querySelectorAll('.tl-year-node').forEach((n) => n.classList.remove('active'));
    root.querySelector(`.tl-year-node[data-index="${i}"]`).classList.add('active');

    mIcon.textContent = y.icon;
    mYear.textContent = y.year;
    mSummary.textContent = y.summary;

    currentSlides = buildSlides(y);
    monthTrack.innerHTML = currentSlides.map(renderSlide).join('');
    wirePhotoCarousels(monthTrack);

    monthDots.innerHTML = currentSlides.map((_, idx) => `<span class="${idx === 0 ? 'on' : ''}"></span>`).join('');

    prevYearBtn.disabled = i === 0;
    nextYearBtn.disabled = i === YEARS.length - 1;

    overlay.classList.add('open');

    requestAnimationFrame(() => {
      monthTrack.scrollTo({ left: 0, behavior: 'auto' });
      updateMonthUI();
    });

    const activeNode = root.querySelector(`.tl-year-node[data-index="${i}"]`);
    activeNode.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
  }

  function closeModal() {
    overlay.classList.remove('open');
    root.querySelectorAll('.tl-year-node').forEach((n) => n.classList.remove('active'));
    activeYearIndex = -1;
  }

  timelineEl.querySelectorAll('.tl-year-node').forEach((node) => {
    node.addEventListener('click', () => openYear(Number(node.dataset.index)));
  });

  monthTrack.addEventListener('scroll', () => {
    window.clearTimeout(monthTrack._t);
    monthTrack._t = window.setTimeout(updateMonthUI, 60);
  });
  monthPrevBtn.addEventListener('click', () => {
    const w = monthTrack.clientWidth || 1;
    const i = Math.round(monthTrack.scrollLeft / w);
    goToMonth(i - 1);
  });
  monthNextBtn.addEventListener('click', () => {
    const w = monthTrack.clientWidth || 1;
    const i = Math.round(monthTrack.scrollLeft / w);
    goToMonth(i + 1);
  });

  root.querySelector('#tl-close-btn').addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  prevYearBtn.addEventListener('click', () => { if (activeYearIndex > 0) openYear(activeYearIndex - 1); });
  nextYearBtn.addEventListener('click', () => { if (activeYearIndex < YEARS.length - 1) openYear(activeYearIndex + 1); });

  document.addEventListener('keydown', (e) => {
    if (!overlay.classList.contains('open')) return;
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowRight') {
      const w = monthTrack.clientWidth || 1;
      goToMonth(Math.round(monthTrack.scrollLeft / w) + 1);
    }
    if (e.key === 'ArrowLeft') {
      const w = monthTrack.clientWidth || 1;
      goToMonth(Math.round(monthTrack.scrollLeft / w) - 1);
    }
  });

  window.addEventListener('resize', () => {
    if (overlay.classList.contains('open')) {
      const w = monthTrack.clientWidth || 1;
      const i = Math.round(monthTrack.scrollLeft / w);
      monthTrack.scrollTo({ left: w * i, behavior: 'auto' });
    }
  });
</script>

<style>
  .tl-root {
    --tl-green-dark: #2f4a3c;
    --tl-green: #4c7a5f;
    --tl-green-light: #8fb89b;
    --tl-sand: #f6f1e7;
    --tl-sand-2: #efe7d6;
    --tl-brown: #7a5c3e;
    --tl-ink: #2b2a26;
    --tl-muted: #6b675d;
    --tl-white: #fffdf9;

    height: 100%;
    display: flex;
    flex-direction: column;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: var(--tl-ink);
  }

  .tl-app {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--tl-sand);
  }

  .tl-app-header {
    flex: 0 0 auto;
    text-align: center;
    padding: clamp(10px, 2.5vh, 22px) 12px clamp(4px, 1vh, 8px);
  }

  .tl-app-header h1 {
    margin: 0;
    font-size: clamp(20px, 4vw, 32px);
    font-weight: 700;
    color: var(--tl-green-dark);
    letter-spacing: 0.5px;
    font-family: inherit;
  }

  .tl-app-header p {
    margin: 4px 0 0;
    font-size: clamp(11px, 1.8vw, 14px);
    color: var(--tl-muted);
  }

  .tl-app-summary {
    flex: 0 0 auto;
    max-width: 640px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 24px);
    text-align: center;
    font-size: clamp(12.5px, 1.6vw, 14.5px);
    line-height: 1.6;
    color: var(--tl-ink);
  }

  .tl-stage {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    position: relative;
  }

  .tl-timeline-scroll {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    padding: 0 6vw;
  }

  .tl-timeline-scroll::-webkit-scrollbar {
    height: 6px;
  }

  .tl-timeline-scroll::-webkit-scrollbar-thumb {
    background: var(--tl-green-light);
    border-radius: 4px;
  }

  .tl-timeline {
    position: relative;
    display: flex;
    align-items: center;
    min-width: max-content;
    gap: clamp(18px, 3.4vw, 48px);
    padding: clamp(30px, 7vh, 60px) 4px clamp(50px, 9vh, 80px);
  }

  .tl-timeline::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 3px;
    background: linear-gradient(to right, var(--tl-green-light), var(--tl-green), var(--tl-green-light));
    transform: translateY(-50%);
    z-index: 0;
    border-radius: 3px;
  }

  .tl-year-node {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    width: clamp(64px, 9vw, 92px);
    scroll-snap-align: center;
    background: none;
    border: none;
    font: inherit;
    color: inherit;
    padding: 0;
  }

  .tl-year-node .tl-dot {
    width: clamp(50px, 7vw, 68px);
    height: clamp(50px, 7vw, 68px);
