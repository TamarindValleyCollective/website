const ERAS: Era[] = [
  {
    key: 'founding',
    name: 'Founding',
    range: '2017–2026',
    poem: [
      'Nine years back, ten hands and a fence line\nheld a barren field near Thakkatti behind.\nEarthwork by earthwork, one workshop, one season —\nthe soil slowly remembered its reason.',
      'A mud hut rose by hand. A wildfire came and went.\nElephants wandered through, uninvited, unbent.\nA transformer vanished one restless July night —\nstill, somehow, the years kept turning out right.',
      'Nine winters deep in, our first true home now stands.\nScroll below — and walk it through, hand in hand.',
    ],
    years: FOUNDING_YEARS,
  },
  // The next era (e.g. "Growth", 2027–2036) gets appended here once it has
  // real years/content.
];

ERAS.forEach((era) => {
  era.years.forEach((y) => {
    y.icon = ICONS[y.year];
  });
});

// Flatten a year's months into one carousel card per photo (or one
// text-only card for a photo-less month) — the same flattening the old
// modal used, so a month with several photos doesn't need its own nested
// scroller inside the year's carousel.
interface YearCard {
  month: string;
  text: string;
  img: string | null;
  fit: 'cover' | 'contain';
}

function buildYearCards(year: YearEntry): YearCard[] {
  const cards: YearCard[] = [];
  year.months.forEach((mo) => {
    const imgs = mo.imgs || [];
    if (imgs.length === 0) {
      cards.push({ month: mo.m, text: mo.t, img: null, fit: 'cover' });
      return;
    }
    const captions = mo.imgCaptions && mo.imgCaptions.length === imgs.length ? mo.imgCaptions : null;
    imgs.forEach((src, idx) => {
      cards.push({
        month: mo.m,
        text: captions ? captions[idx] : mo.t,
        img: src,
        fit: (mo.imgFit && mo.imgFit[idx]) || 'cover',
      });
    });
  });
  return cards;
}

const activeEra = ERAS[0];
const yearSections = activeEra.years.map((y) => ({
  ...y,
  cards: buildYearCards(y),
}));
---

<div class="jt-root">
  <div class="jt-rail" aria-hidden="true"><div class="jt-rail-fill" id="jt-rail-fill"></div></div>

  <nav class="jt-index" id="jt-index" aria-label="Jump to a year">
    <p class="jt-index-title">Our Journey</p>
    {yearSections.map((y, i) => (
      <button type="button" class="jt-index-item" data-target={`jt-y-${i}`}>
        <span class="jt-index-num">{String(i).padStart(2, '0')}</span>
        <span class="jt-index-dash" aria-hidden="true"></span>
        <span class="jt-index-label">{y.year} — {y.summary}</span>
      </button>
    ))}
  </nav>

  <section class="jt-hero">
    <p class="jt-hero-eyebrow">Tamarind Valley Collective · Est. {activeEra.years[0].year}</p>
    <div class="jt-hero-poem">
      {activeEra.poem.map((stanza) => <p>{stanza}</p>)}
    </div>
    <div class="jt-scroll-cue" aria-hidden="true">
      <span class="jt-scroll-cue-line"></span>
      Scroll
    </div>
  </section>

  {yearSections.map((y, i) => (
    <section class="jt-year" id={`jt-y-${i}`} data-year-index={i}>
      <div class="jt-year-bg" aria-hidden="true">
        {y.cards.find((c) => c.img) && <img src={y.cards.find((c) => c.img)!.img!} alt="" loading="lazy" />}
      </div>
      <div class="jt-year-head">
        <p class="jt-year-eyebrow" data-eyebrow={i}>{y.cards[0].month} {y.year}</p>
        <p class="jt-year-num">{y.year}</p>
        <p class="jt-year-summary">{y.summary}</p>
      </div>
      <div class="jt-carousel-wrap">
        <div class="jt-carousel" data-carousel={i} tabindex="0" role="group" aria-label={`${y.year} months`}>
          {y.cards.map((c) => (
            c.img ? (
              <div class="jt-card" role="button" tabindex="0" aria-label={`View photo — ${c.month} ${y.year}`}>
                <img
                  src={c.img}
                  alt={`${c.month} ${y.year} photo`}
                  loading="lazy"
                  style={c.fit === 'contain' ? 'object-fit:contain;background:var(--jt-surface);' : ''}
                />
                <span class="jt-card-hint" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 3H4v5M15 3h5v5M9 21H4v-5M15 21h5v-5"/></svg>
                </span>
                <div class="jt-card-text">
                  <p class="jt-card-month">{c.month}</p>
                  <p class="jt-card-body">{c.text}</p>
                </div>
              </div>
            ) : (
              <div class="jt-card jt-card--no-photo">
                <div class="jt-card-text">
                  <p class="jt-card-month">{c.month}</p>
                  <p class="jt-card-body">{c.text}</p>
                </div>
              </div>
            )
          ))}
        </div>
        <div class="jt-carousel-controls">
          <button type="button" class="jt-car-btn" data-prev={i} aria-label={`Previous month in ${y.year}`}>‹</button>
          <button type="button" class="jt-car-btn" data-next={i} aria-label={`Next month in ${y.year}`}>›</button>
          <div class="jt-car-dots" data-dots={i}>
            {y.cards.map((_, ci) => <span class={ci === 0 ? 'on' : ''}></span>)}
          </div>
        </div>
      </div>
    </section>
  ))}

  <div class="jt-lightbox" id="jt-lightbox" aria-hidden="true">
    <button type="button" class="jt-lb-close" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 5l14 14M19 5L5 19"/></svg>
    </button>
    <button type="button" class="jt-lb-nav jt-lb-prev" aria-label="Previous photo">‹</button>
    <button type="button" class="jt-lb-nav jt-lb-next" aria-label="Next photo">›</button>
    <div class="jt-lb-stage">
      <img class="jt-lb-img" src="" alt="" />
      <div class="jt-lb-caption">
        <p class="jt-lb-month"></p>
        <p class="jt-lb-body"></p>
      </div>
    </div>
  </div>
</div>

<script>
  const root = document.querySelector('.jt-root')!;
  const railFill = root.querySelector('#jt-rail-fill') as HTMLElement;
  const indexItems = Array.from(root.querySelectorAll('.jt-index-item')) as HTMLButtonElement[];
  const yearSectionEls = Array.from(root.querySelectorAll('.jt-year')) as HTMLElement[];

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  // Hand-rolled animation of scrollLeft, used instead of native
  // `scrollTo({behavior:'smooth'})` — see the note in goTo() below for why.
  // Snap is turned off for the duration: scroll-snap-type:mandatory can
  // treat each in-progress frame of the tween as an uncommitted gesture
  // and yank scrollLeft back toward the start, which fights a manual
  // tween just as it fought the native one.
  function animateScrollLeft(el: HTMLElement, target: number, duration = 380) {
    const start = el.scrollLeft;
    const change = target - start;
    if (change === 0) return;
    if (prefersReducedMotion) {
      el.scrollLeft = target;
      return;
    }
    const prevSnap = el.style.scrollSnapType;
    el.style.scrollSnapType = 'none';
    const startTime = performance.now();
    function step(now: number) {
      const t = Math.min(1, (now - startTime) / duration);
      el.scrollLeft = start + change * easeOutCubic(t);
      if (t < 1) {
        requestAnimationFrame(step);
      } else {
        el.style.scrollSnapType = prevSnap;
      }
    }
    requestAnimationFrame(step);
  }

  indexItems.forEach((item) => {
    item.addEventListener('click', () => {
      document.getElementById(item.dataset.target!)?.scrollIntoView({ behavior: 'smooth' });
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const idx = yearSectionEls.indexOf(entry.target as HTMLElement);
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          indexItems.forEach((it) => it.classList.remove('active'));
          indexItems[idx]?.classList.add('active');
        }
      });
    },
    { threshold: 0.5 },
  );
  yearSectionEls.forEach((s) => observer.observe(s));

  window.addEventListener(
    'scroll',
    () => {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? Math.min(100, Math.max(0, (window.scrollY / total) * 100)) : 0;
      if (railFill) railFill.style.height = `${pct}%`;
    },
    { passive: true },
  );

  // Per-year carousel: scroll-snap track + arrows + dots + a synced
  // "current month" eyebrow label, mirroring the old modal's month
  // carousel but living inline instead of behind a click. Cards overlap
  // (negative margin, see CSS) and scale up when active/adjacent for the
  // "fanned stack" look — clicking a photo card opens the shared lightbox
  // below instead of navigating away.
  const lightbox = document.getElementById('jt-lightbox') as HTMLElement;
  const lbImg = lightbox.querySelector('.jt-lb-img') as HTMLImageElement;
  const lbMonth = lightbox.querySelector('.jt-lb-month') as HTMLElement;
  const lbBody = lightbox.querySelector('.jt-lb-body') as HTMLElement;
  const lbClose = lightbox.querySelector('.jt-lb-close') as HTMLButtonElement;
  const lbPrev = lightbox.querySelector('.jt-lb-prev') as HTMLButtonElement;
  const lbNext = lightbox.querySelector('.jt-lb-next') as HTMLButtonElement;

  let lbPhotoCards: HTMLElement[] = [];
  let lbPos = 0;
  let lastFocused: HTMLElement | null = null;

  function renderLightbox() {
    const card = lbPhotoCards[lbPos];
    const img = card.querySelector('img') as HTMLImageElement;
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lbMonth.textContent = card.querySelector('.jt-card-month')?.textContent || '';
    lbBody.textContent = card.querySelector('.jt-card-body')?.textContent || '';
    lbPrev.disabled = lbPos === 0;
    lbNext.disabled = lbPos === lbPhotoCards.length - 1;
  }

  function openLightbox(photoCards: HTMLElement[], card: HTMLElement, trigger: HTMLElement) {
    lbPhotoCards = photoCards;
    lbPos = photoCards.indexOf(card);
    lastFocused = trigger;
    renderLightbox();
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lastFocused?.focus();
  }

  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  lbPrev.addEventListener('click', () => {
    if (lbPos > 0) { lbPos--; renderLightbox(); }
  });
  lbNext.addEventListener('click', () => {
    if (lbPos < lbPhotoCards.length - 1) { lbPos++; renderLightbox(); }
  });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') lbNext.click();
    if (e.key === 'ArrowLeft') lbPrev.click();
  });

  yearSectionEls.forEach((section, yi) => {
    const carEl = section.querySelector(`[data-carousel="${yi}"]`) as HTMLElement;
    const dotsEl = section.querySelector(`[data-dots="${yi}"]`) as HTMLElement;
    const eyebrowEl = section.querySelector(`[data-eyebrow="${yi}"]`) as HTMLElement;
    const prevBtn = section.querySelector(`[data-prev="${yi}"]`) as HTMLButtonElement;
    const nextBtn = section.querySelector(`[data-next="${yi}"]`) as HTMLButtonElement;
    const cards = Array.from(carEl.children) as HTMLElement[];
    const months = cards.map((c) => c.querySelector('.jt-card-month')?.textContent || '');
    const photoCards = cards.filter((c) => !c.classList.contains('jt-card--no-photo'));

    // Cards overlap via negative margin, so the step between snap points
    // isn't a fixed card-width-plus-gap — measure the real DOM distance
    // between two consecutive cards instead of assuming one.
    function step(): number {
      return cards.length > 1 ? cards[1].offsetLeft - cards[0].offsetLeft : cards[0].getBoundingClientRect().width;
    }

    function currentIndex(): number {
      const w = step();
      return Math.max(0, Math.min(cards.length - 1, Math.round(carEl.scrollLeft / w)));
    }

    function goTo(i: number) {
      i = Math.max(0, Math.min(cards.length - 1, i));
      // Native `scrollTo({behavior:'smooth'})` doesn't reliably animate on
      // this track — verified it silently no-ops even with scroll-snap
      // turned off first, not just "gets fought" by snap as previously
      // assumed. Driving scrollLeft by hand every frame sidesteps the
      // native smooth-scroll implementation entirely, so it can't be
      // silently dropped; scroll-snap only re-asserts once a gesture
      // settles, and the target is already a valid snap point.
      animateScrollLeft(carEl, step() * i);
    }

    function updateUI() {
      const i = currentIndex();
      dotsEl.querySelectorAll('span').forEach((d, di) => d.classList.toggle('on', di === i));
      const yearLabel = section.querySelector('.jt-year-num')?.textContent || '';
      eyebrowEl.textContent = `${months[i]} ${yearLabel}`;
      prevBtn.disabled = i === 0;
      nextBtn.disabled = i === cards.length - 1;
      cards.forEach((c, ci) => {
        c.classList.toggle('is-active', ci === i);
        c.classList.toggle('is-near', Math.abs(ci - i) === 1);
      });
    }

    // rAF-throttled rather than debounced-after-stop: the old version only
    // updated is-active/is-near once scrolling fully settled, so a smooth
    // scroll (or a drag) landed on the new card with no transition — the
    // scale/fade would just snap in 60ms later. Tracking scroll position
    // every frame instead makes the fan-forward effect sweep continuously
    // through the stack as you scroll, animated or dragged.
    let rafPending = false;
    carEl.addEventListener(
      'scroll',
      () => {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(() => {
          rafPending = false;
          updateUI();
        });
      },
      { passive: true },
    );

    prevBtn.addEventListener('click', () => goTo(currentIndex() - 1));
    nextBtn.addEventListener('click', () => goTo(currentIndex() + 1));

    carEl.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') goTo(currentIndex() + 1);
      if (e.key === 'ArrowLeft') goTo(currentIndex() - 1);
    });

    // A touch/trackpad drag-scroll ends with a native 'click' on release —
    // guard against that opening the lightbox unintentionally by only
    // treating it as a tap when the pointer barely moved.
    let downX = 0;
    let downY = 0;
    let dragged = false;
    carEl.addEventListener('pointerdown', (e) => {
      downX = e.clientX;
      downY = e.clientY;
      dragged = false;
    });
    carEl.addEventListener('pointermove', (e) => {
      if (Math.abs(e.clientX - downX) > 6 || Math.abs(e.clientY - downY) > 6) dragged = true;
    });

    cards.forEach((cardEl) => {
      if (cardEl.classList.contains('jt-card--no-photo')) return;
      const open = () => {
        if (dragged) return;
        openLightbox(photoCards, cardEl, cardEl);
      };
      cardEl.addEventListener('click', open);
      cardEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openLightbox(photoCards, cardEl, cardEl);
        }
      });
    });

    updateUI();
  });
</script>

