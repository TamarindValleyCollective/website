---
// Full-bleed scrollytelling redesign of the "Our Journey" timeline, replacing
// the earlier click-a-dot-to-open-a-modal version. Each year is now its own
// full-viewport section with a real hero photo; a year's months live as a
// swipeable carousel directly in that section instead of behind a click.
// Reached via three rounds of live-rendered comparisons before this was
// built — see CHANGELOG.md.
//
// Structured around "eras" so this scales past a single flat year row: each
// era owns its own poem + year sections. With exactly one era (today), it
// renders directly — no era-picker. The moment a second era gets real
// years, this needs a picker step before the hero (not built yet, since
// there's nothing to pick between).
interface MonthEntry {
  m: string;
  t: string;
  imgs: string[];
  // Per-image captions, same length as imgs — shown in place of the
  // month's single `t` as the carousel is swiped. Omit to just repeat `t`
  // for every photo (the default when one caption covers the whole
  // month's single event).
  imgCaptions?: string[];
  // Per-image object-fit override, same length as imgs. Real farm
  // photography looks best cropped to fill the frame ('cover', the
  // default); flat graphics like the logo need 'contain' so nothing gets
  // cropped off.
  imgFit?: ('cover' | 'contain')[];
}

interface YearEntry {
  year: number;
  icon: string;
  summary: string;
  intro: string;
  months: MonthEntry[];
}

interface Era {
  key: string;
  name: string;
  range: string;
  // Poem stanzas for this era's hero. Each string is one stanza; internal
  // line breaks are literal "\n" and rendered via CSS white-space: pre-line
  // rather than embedded <br/> markup.
  poem: string[];
  years: YearEntry[];
}

// Consistent monoline SVG icons (24x24 viewBox, single stroke weight) instead
// of raw emoji — different emoji glyphs render at wildly different visual
// sizes/baselines even at the same font-size.
