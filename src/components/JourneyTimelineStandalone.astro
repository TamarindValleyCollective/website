const ERAS: Era[] = [
  {
    key: 'founding',
    name: 'Founding',
    range: '2017–2026',
    poem: [
      'Nine years back, ten hands and a fence line\nheld a barren field near Thakkatti behind.\nEarthwork by earthwork, one workshop, one season —\nthe soil slowly remembered its reason.',
      'A mud hut rose by hand. A wildfire came and went.\nElephants wandered through, uninvited, unbent.\nA transformer vanished one restless July night —\nstill, somehow, the years kept turning out right.',
      'Nine winters deep in, our first true home now stands.\nScroll below — and walk it through, hand in hand.',
    ],
    years: FOUNDING_YEARS,
  },
  // The next era (e.g. "Growth", 2027–2036) gets appended here once it has
  // real years/content.
];

ERAS.forEach((era) => {
  era.years.forEach((y) => {
    y.icon = ICONS[y.year];
  });
});

// Flatten a year's months into one carousel card per photo (or one
// text-only card for a photo-less month) — the same flattening the old
// modal used, so a month with several photos doesn't need its own nested
// scroller inside the year's carousel.
interface YearCard {
  month: string;
  text: string;
  img: string | null;
  fit: 'cover' | 'contain';
}

function buildYearCards(year: YearEntry): YearCard[] {
  const cards: YearCard[] = [];
  year.months.forEach((mo) => {
    const imgs = mo.imgs || [];
    if (imgs.length === 0) {
      cards.push({ month: mo.m, text: mo.t, img: null, fit: 'cover' });
      return;
    }
    const captions = mo.imgCaptions && mo.imgCaptions.length === imgs.length ? mo.imgCaptions : null;
    imgs.forEach((src, idx) => {
      cards.push({
        month: mo.m,
        text: captions ? captions[idx] : mo.t,
        img: src,
        fit: (mo.imgFit && mo.imgFit[idx]) || 'cover',
      });
    });
  });
  return cards;
}

const activeEra = ERAS[0];
const yearSections = activeEra.years.map((y) => ({
  ...y,
  cards: buildYearCards(y),
}));
---

<div class="jt-root">
  <div class="jt-rail" aria-hidden="true"><div class="jt-rail-fill" id="jt-rail-fill"></div></div>

  <nav class="jt-index" id="jt-index" aria-label="Jump to a year">
    <p class="jt-index-title">Our Journey</p>
    {yearSections.map((y, i) => (
      <button type="button" class="jt-index-item" data-target={`jt-y-${i}`}>
        <span class="jt-index-num">{String(i).padStart(2, '0')}</span>
        <span class="jt-index-dash" aria-hidden="true"></span>
        <span class="jt-index-label">{y.year} — {y.summary}</span>
      </button>
    ))}
  </nav>

  <section class="jt-hero">
    <p class="jt-hero-eyebrow">Tamarind Valley Collective · Est. {activeEra.years[0].year}</p>
    <div class="jt-hero-poem">
      {activeEra.poem.map((stanza) => <p>{stanza}</p>)}
    </div>
    <div class="jt-scroll-cue" aria-hidden="true">
      <span class="jt-scroll-cue-line"></span>
      Scroll
    </div>
  </section>

  {yearSections.map((y, i) => (
    <section class="jt-year" id={`jt-y-${i}`} data-year-index={i}>
      <div class="jt-year-bg" aria-hidden="true">
        {y.cards.find((c) => c.img) && <img src={y.cards.find((c) => c.img)!.img!} alt="" loading="lazy" />}
      </div>
      <div class="jt-year-head">
        <p class="jt-year-eyebrow" data-eyebrow={i}>{y.cards[0].month} {y.year}</p>
        <p class="jt-year-num">{y.year}</p>
        <p class="jt-year-summary">{y.summary}</p>
      </div>
      <div class="jt-carousel-wrap">
        <div class="jt-carousel" data-carousel={i} tabindex="0" role="group" aria-label={`${y.year} months`}>
          {y.cards.map((c) => (
            c.img ? (
              <div class="jt-card">
                <img
                  src={c.img}
                  alt={`${c.month} ${y.year} photo`}
                  loading="lazy"
                  style={c.fit === 'contain' ? 'object-fit:contain;background:var(--jt-surface);' : ''}
                />
                <div class="jt-card-text">
                  <p class="jt-card-month">{c.month}</p>
                  <p class="jt-card-body">{c.text}</p>
                </div>
              </div>
            ) : (
              <div class="jt-card jt-card--no-photo">
                <div class="jt-card-text">
                  <p class="jt-card-month">{c.month}</p>
                  <p class="jt-card-body">{c.text}</p>
                </div>
              </div>
            )
          ))}
        </div>
        <div class="jt-carousel-controls">
          <button type="button" class="jt-car-btn" data-prev={i} aria-label={`Previous month in ${y.year}`}>‹</button>
          <button type="button" class="jt-car-btn" data-next={i} aria-label={`Next month in ${y.year}`}>›</button>
          <div class="jt-car-dots" data-dots={i}>
            {y.cards.map((_, ci) => <span class={ci === 0 ? 'on' : ''}></span>)}
          </div>
        </div>
      </div>
    </section>
  ))}
</div>

<script>
  const root = document.querySelector('.jt-root')!;
  const railFill = root.querySelector('#jt-rail-fill') as HTMLElement;
  const indexItems = Array.from(root.querySelectorAll('.jt-index-item')) as HTMLButtonElement[];
  const yearSectionEls = Array.from(root.querySelectorAll('.jt-year')) as HTMLElement[];

  indexItems.forEach((item) => {
    item.addEventListener('click', () => {
      document.getElementById(item.dataset.target!)?.scrollIntoView({ behavior: 'smooth' });
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const idx = yearSectionEls.indexOf(entry.target as HTMLElement);
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          indexItems.forEach((it) => it.classList.remove('active'));
          indexItems[idx]?.classList.add('active');
        }
      });
    },
    { threshold: 0.5 },
  );
  yearSectionEls.forEach((s) => observer.observe(s));

  window.addEventListener(
    'scroll',
    () => {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? Math.min(100, Math.max(0, (window.scrollY / total) * 100)) : 0;
      if (railFill) railFill.style.height = `${pct}%`;
    },
    { passive: true },
  );

  // Per-year carousel: scroll-snap track + arrows + dots + a synced
  // "current month" eyebrow label, mirroring the old modal's month
  // carousel but living inline instead of behind a click.
  yearSectionEls.forEach((section, yi) => {
    const carEl = section.querySelector(`[data-carousel="${yi}"]`) as HTMLElement;
    const dotsEl = section.querySelector(`[data-dots="${yi}"]`) as HTMLElement;
    const eyebrowEl = section.querySelector(`[data-eyebrow="${yi}"]`) as HTMLElement;
    const prevBtn = section.querySelector(`[data-prev="${yi}"]`) as HTMLButtonElement;
    const nextBtn = section.querySelector(`[data-next="${yi}"]`) as HTMLButtonElement;
    const cards = Array.from(carEl.children) as HTMLElement[];
    const months = cards.map((c) => c.querySelector('.jt-card-month')?.textContent || '');

    function currentIndex(): number {
      const w = cards[0].getBoundingClientRect().width + 16;
      return Math.max(0, Math.min(cards.length - 1, Math.round(carEl.scrollLeft / w)));
    }

    function goTo(i: number) {
      i = Math.max(0, Math.min(cards.length - 1, i));
      const w = cards[0].getBoundingClientRect().width + 16;
      // 'smooth' here fights this track's scroll-snap-type: mandatory —
      // the snap machinery can cancel the animation mid-flight and leave
      // scrollLeft unchanged. 'auto' sidesteps it; native swipe/trackpad
      // scrolling still feels smooth via the snap points themselves.
      carEl.scrollTo({ left: w * i, behavior: 'auto' });
    }

    function updateUI() {
      const i = currentIndex();
      dotsEl.querySelectorAll('span').forEach((d, di) => d.classList.toggle('on', di === i));
      const yearLabel = section.querySelector('.jt-year-num')?.textContent || '';
      eyebrowEl.textContent = `${months[i]} ${yearLabel}`;
      prevBtn.disabled = i === 0;
      nextBtn.disabled = i === cards.length - 1;
    }

    let scrollTimer: number;
    carEl.addEventListener(
      'scroll',
      () => {
        window.clearTimeout(scrollTimer);
        scrollTimer = window.setTimeout(updateUI, 60);
      },
      { passive: true },
    );

    prevBtn.addEventListener('click', () => goTo(currentIndex() - 1));
    nextBtn.addEventListener('click', () => goTo(currentIndex() + 1));

    carEl.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') goTo(currentIndex() + 1);
      if (e.key === 'ArrowLeft') goTo(currentIndex() - 1);
    });

    updateUI();
  });
</script>

<style define:vars={{
  'jt-green': 'var(--tvc-green)',
  'jt-orange': 'var(--tvc-orange)',
}}>
  /* This page commits deliberately to its own dark, immersive palette —
     distinct from the site's usual cream editorial pages — the way this
     feature has its own "chapter" feel. Accent colors still map onto the
     site's real green/orange tokens so it doesn't feel like an unrelated
     embedded widget; only the ground (near-black vs. cream) is different. */
  .jt-root {
    --jt-bg: #0e1710;
    --jt-bg-soft: #14201a;
    --jt-surface: #1c2a21;
    --jt-line: rgba(251, 250, 246, 0.14);
    --jt-cream: #fbfaf6;
    --jt-text-soft: rgba(251, 250, 246, 0.6);

    position: relative;
    background: var(--jt-bg);
    color: var(--jt-cream);
    font-family: var(--font-body);
  }

  /* ---------- Sidebar index ---------- */
  .jt-index {
    position: fixed;
    left: 40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .jt-index-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--jt-text-soft);
    margin: 0 0 16px;
  }

  .jt-index-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 7px 0;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.35s ease;
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    text-align: left;
  }

  .jt-index-item.active { opacity: 1; }

  .jt-index-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    color: var(--jt-text-soft);
    width: 34px;
    flex: 0 0 auto;
    transition: color 0.35s ease;
  }

  .jt-index-item.active .jt-index-num { color: var(--jt-orange); }

  .jt-index-dash {
    width: 14px;
