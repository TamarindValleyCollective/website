---
// Faithful port of tvc_timeline.html into an Astro component. Kept as
// close to the original markup/CSS/JS as possible (same class/id names,
// prefixed with "tl-" to avoid clashing with the rest of the site, and
// wrapped in .tl-root so the color variables — declared once there —
// reach both the inline app and the modal overlay, which is a sibling
// of .tl-app, not a descendant of it, since it's position:fixed).
interface MonthEntry {
  m: string;
  t: string;
  imgs: string[];
  // Per-image captions, same length as imgs — shown in place of the
  // month's single `t` as the photo carousel is swiped. Omit to just
  // repeat `t` for every photo (the default when one caption covers
  // the whole month's single event).
  imgCaptions?: string[];
  // Per-image object-fit override, same length as imgs. Real farm
  // photography looks best cropped to fill the frame ('cover', the
  // default); flat graphics like the logo need 'contain' so nothing
  // gets cropped off.
  imgFit?: ('cover' | 'contain')[];
}

interface YearEntry {
  year: number;
  icon: string;
  summary: string;
  intro: string;
  months: MonthEntry[];
}

const YEARS: YearEntry[] = [
