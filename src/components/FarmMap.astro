---
// Coordinates are percentages of the image frame, hand-estimated against
// the hand-drawn arrow tips already baked into hero.jpg (Camp Site, Solar
// Shed, etc.) -- this section exists so those labels are a real clickable
// UI instead of cursive text visitors have to squint at.
interface Hotspot {
  label: string;
  x: number;
  y: number;
}

const HOTSPOTS: Hotspot[] = [
  { label: 'Camp Site', x: 45.9, y: 59.7 },
  { label: 'New Lunch Hut', x: 48.4, y: 56.6 },
  { label: 'Old Lunch Hut', x: 53.9, y: 64.5 },
  { label: 'Mudhut', x: 57.4, y: 66.0 },
  { label: 'Elvin Kere', x: 50.2, y: 86.1 },
  { label: 'Syntropic Plot 2', x: 56.5, y: 84.5 },
  { label: 'Well', x: 63.3, y: 78.2 },
  { label: 'Syntropic Plot 1', x: 61.5, y: 87.7 },
  { label: "Madhav's House", x: 70.9, y: 57.2 },
  { label: 'Farmers Quarters 2', x: 79.8, y: 60.8 },
  { label: 'Solar Shed', x: 87.9, y: 52.4 },
  { label: 'Mango Tree', x: 89.6, y: 55.3 },
  { label: 'Farmers Quarters 1', x: 94.8, y: 51.8 },
];

// Tooltips open to the right by default; pins past this far right would push
// their label past the frame (and on narrow viewports, past the screen
// edge), so those flip to open leftward instead.
const FLIP_THRESHOLD = 75;
---

<section class="farm-map section">
  <div class="wrapper">
    <div class="section-label">
      <span class="dot"></span>
      <h2>Explore the land</h2>
      <span class="section-label__hint">Tap a pin to see what's there</span>
    </div>

    <div class="farm-map__frame">
      <div class="farm-map__clip">
        <img class="farm-map__img" src="/images/pages/home/hero.jpg" alt="Aerial view of the TVC farm, uncropped" loading="lazy" />
      </div>
      {HOTSPOTS.map((h) => (
        <button type="button" class:list={['farm-map__pin', { 'farm-map__pin--flip': h.x > FLIP_THRESHOLD }]} style={`left:${h.x}%; top:${h.y}%;`}>
          <span class="farm-map__pin-dot"></span>
          <span class="farm-map__pin-label">{h.label}</span>
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  .farm-map {
    padding-top: 56px;
    padding-bottom: 56px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .section-label h2 {
    margin: 0;
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--tvc-green);
    flex-shrink: 0;
  }

  .section-label__hint {
    font-size: 0.78rem;
    color: var(--tvc-muted, var(--tvc-ink-soft));
    letter-spacing: 0.02em;
  }

  .farm-map__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4204 / 1330;
  }

  /* Clipping lives on its own inner layer, not .farm-map__frame itself --
     pins are positioned relative to .farm-map__frame too, and if it were
     the one with overflow:hidden, tooltips near the left/right edge would
     get cut off along with it. */
  .farm-map__clip {
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .farm-map__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .farm-map__pin {
    position: absolute;
    transform: translate(-50%, -50%);
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: none;
    padding: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .farm-map__pin-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--tvc-orange);
    border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.45), 0 0 0 4px rgba(247, 133, 32, 0.35);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .farm-map__pin:hover .farm-map__pin-dot,
  .farm-map__pin.is-open .farm-map__pin-dot {
    transform: scale(1.3);
  }

  .farm-map__pin-label {
    position: absolute;
    left: calc(100% + 6px);
    top: 50%;
    transform: translateY(-50%);
    background: rgba(23, 41, 31, 0.88);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.12s ease;
    pointer-events: none;
  }

  .farm-map__pin--flip .farm-map__pin-label {
    left: auto;
    right: calc(100% + 6px);
  }

  .farm-map__pin:hover .farm-map__pin-label,
  .farm-map__pin:focus-visible .farm-map__pin-label,
  .farm-map__pin.is-open .farm-map__pin-label {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 640px) {
    .farm-map__pin-dot {
      width: 14px;
      height: 14px;
    }
  }
</style>

<script>
  const pins = document.querySelectorAll<HTMLButtonElement>('.farm-map__pin');
  pins.forEach((pin) => {
    pin.addEventListener('click', () => {
      const wasOpen = pin.classList.contains('is-open');
      pins.forEach((p) => p.classList.remove('is-open'));
      if (!wasOpen) pin.classList.add('is-open');
    });
  });
</script>
