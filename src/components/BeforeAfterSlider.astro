---
interface Props {
  before: string;
  beforeAlt: string;
  beforeLabel: string;
  after: string;
  afterAlt: string;
  afterLabel: string;
}

const { before, beforeAlt, beforeLabel, after, afterAlt, afterLabel } = Astro.props;
---

<div class="ba-slider" style="--ba-pos: 50%;">
  <img class="ba-slider__img ba-slider__img--after" src={after} alt={afterAlt} loading="lazy" />
  <div class="ba-slider__before-wrap">
    <img class="ba-slider__img ba-slider__img--before" src={before} alt={beforeAlt} loading="lazy" />
  </div>

  <div class="ba-slider__handle" aria-hidden="true">
    <span class="ba-slider__grip">↔</span>
  </div>

  <span class="ba-slider__tag ba-slider__tag--before">{beforeLabel}</span>
  <span class="ba-slider__tag ba-slider__tag--after">{afterLabel}</span>

  <input
    type="range"
    class="ba-slider__input"
    min="0"
    max="100"
    value="50"
    aria-label={`Drag to compare ${beforeLabel} and ${afterLabel}`}
  />
</div>

<style>
  .ba-slider {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    /* Set by the range input's own input event, read by clip-path/left below */
    --ba-pos: 50%;
  }

  .ba-slider__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-slider__before-wrap {
    position: absolute;
    inset: 0;
    clip-path: inset(0 calc(100% - var(--ba-pos)) 0 0);
  }

  .ba-slider__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--ba-pos);
    width: 3px;
    background: #fff;
    transform: translateX(-50%);
    pointer-events: none;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.15);
  }

  .ba-slider__grip {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    box-shadow: var(--shadow-soft);
    color: var(--tvc-ink);
  }

  .ba-slider__tag {
    position: absolute;
    top: 14px;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #fff;
    background: rgba(23, 41, 31, 0.65);
    pointer-events: none;
  }

  .ba-slider__tag--before {
    left: 14px;
  }

  .ba-slider__tag--after {
    right: 14px;
  }

  .ba-slider__input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: ew-resize;
    appearance: none;
    -webkit-appearance: none;
  }

  .ba-slider__input::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    height: 100%;
  }

  .ba-slider__input:focus-visible ~ .ba-slider__handle {
    outline: 2px solid var(--tvc-orange);
    outline-offset: 4px;
  }
</style>

<script>
  document.querySelectorAll<HTMLInputElement>('.ba-slider__input').forEach((input) => {
    const slider = input.closest<HTMLElement>('.ba-slider');
    if (!slider) return;
    input.addEventListener('input', () => {
      slider.style.setProperty('--ba-pos', `${input.value}%`);
    });
  });
</script>
