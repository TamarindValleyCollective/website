---
const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/farm.tvc' },
  { label: 'Twitter', href: 'https://twitter.com/TVCFarm' },
  { label: 'Instagram', href: 'https://www.instagram.com/tamarindvalleycollective/' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrapper footer__top">
    <a class="footer__brand" href="/">
      <img src="/images/brand/tvc-logo-mark.png" alt="Tamarind Valley Collective" width="36" height="36" />
      <span>Tamarind Valley Collective</span>
    </a>
    <p class="footer__blurb">A 100-acre permaculture farm collectively owned by 53 families, regenerating degraded land near Kanakapura since 2017.</p>
    <div class="footer__social">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
      ))}
    </div>
  </div>
  <div class="wrapper footer__bottom">
    <p class="footer__copy">© {year} Tamarind Valley Collective. All rights reserved.</p>
    <p class="footer__legal">
      <a href="/privacy">Privacy &amp; Cookies</a>
      <span aria-hidden="true">·</span>
      <button type="button" id="footer-cookie-prefs">Cookie preferences</button>
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--tvc-green-dark);
    color: #eef5ee;
    margin-top: 64px;
  }

  .footer__top {
    padding: 20px 24px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px 24px;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #fff;
    font-family: var(--font-wordmark);
    font-weight: 700;
    font-size: 0.95rem;
    flex-shrink: 0;
  }

  .footer__brand img {
    border-radius: 50%;
  }

  .footer__blurb {
    margin: 0;
    font-size: 0.8rem;
    color: #b9d0bc;
    max-width: 46ch;
    flex: 1 1 320px;
  }

  .footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    flex-shrink: 0;
  }

  .footer__social a {
    color: #eef5ee;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .footer__social a:hover {
    color: var(--tvc-orange);
  }

  .footer__bottom {
    padding: 10px 24px;
    border-top: 1px solid rgba(238, 245, 238, 0.12);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 6px 16px;
  }

  .footer__copy {
    font-size: 0.75rem;
    color: #b9d0bc;
    margin: 0;
  }

  .footer__legal {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #b9d0bc;
    margin: 0;
  }

  .footer__legal a {
    color: #eef5ee;
  }

  .footer__legal a:hover {
    color: var(--tvc-orange);
  }

  .footer__legal button {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    padding: 0;
    color: #eef5ee;
    font: inherit;
    font-size: 0.75rem;
    text-decoration: underline;
    cursor: pointer;
  }

  .footer__legal button:hover {
    color: var(--tvc-orange);
  }

  @media (max-width: 640px) {
    .footer__top {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 20px 24px 14px;
    }

    .footer__blurb {
      max-width: 40ch;
      flex: 0 1 auto;
    }

    .footer__social {
      justify-content: center;
    }

    .footer__bottom {
      flex-direction: column;
      justify-content: center;
      text-align: center;
      padding: 12px 24px 20px;
    }
  }
</style>

<script>
  document.getElementById('footer-cookie-prefs')?.addEventListener('click', () => {
    window.dispatchEvent(new Event('tvc:open-cookie-preferences'));
  });
</script>
