---
const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/farm.tvc' },
  { label: 'Twitter', href: 'https://twitter.com/TVCFarm' },
  { label: 'Instagram', href: 'https://www.instagram.com/tamarindvalleycollective/' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrapper footer__inner">
    <a class="footer__brand" href="/">
      <img src="/images/brand/tvc-logo-mark.png" alt="Tamarind Valley Collective" width="52" height="52" />
      <span>Tamarind Valley Collective</span>
    </a>
    <p class="footer__blurb">A 100-acre permaculture farm collectively owned by 53 families, regenerating degraded land near Kanakapura since 2017.</p>
    <div class="footer__social">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
      ))}
    </div>
    <p class="footer__copy">© {year} Tamarind Valley Collective. All rights reserved.</p>
    <p class="footer__legal">
      <a href="/privacy">Privacy &amp; Cookies</a>
      <span aria-hidden="true">·</span>
      <button type="button" id="footer-cookie-prefs">Cookie preferences</button>
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--tvc-green-dark);
    color: #eef5ee;
    margin-top: 64px;
  }

  .footer__inner {
    padding: 40px 24px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: #fff;
    font-family: var(--font-wordmark);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .footer__brand img {
    border-radius: 50%;
  }

  .footer__blurb {
    margin: 0;
    font-size: 0.85rem;
    color: #b9d0bc;
    max-width: 46ch;
  }

  .footer__social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px;
  }

  .footer__social a {
    color: #eef5ee;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .footer__social a:hover {
    color: var(--tvc-orange);
  }

  .footer__copy {
    font-size: 0.8rem;
    color: #b9d0bc;
    margin: 0;
  }

  .footer__legal {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 0.8rem;
    color: #b9d0bc;
    margin: 0;
  }

  .footer__legal a {
    color: #eef5ee;
  }

  .footer__legal a:hover {
    color: var(--tvc-orange);
  }

  .footer__legal button {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    padding: 0;
    color: #eef5ee;
    font: inherit;
    font-size: 0.8rem;
    text-decoration: underline;
    cursor: pointer;
  }

  .footer__legal button:hover {
    color: var(--tvc-orange);
  }
</style>

<script>
  document.getElementById('footer-cookie-prefs')?.addEventListener('click', () => {
    window.dispatchEvent(new Event('tvc:open-cookie-preferences'));
  });
</script>
