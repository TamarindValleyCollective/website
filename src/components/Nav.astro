---
import { EXPLORE_LINKS, ENGAGE_LINKS } from '../data/site-map';

// Mirrors the homepage's own Explore/Engage fork (src/pages/index.astro) so
// the nav reads as the same map wherever you are on the site, not a
// different grouping than the one you land on at "/". Both are wide
// (7 items each) because a single column runs uncomfortably tall — see
// .nav__dropdown--wide below for the two-column treatment that needs.
const navItems = [
  { label: 'Explore', wide: true, children: EXPLORE_LINKS },
  { label: 'Engage', wide: true, children: ENGAGE_LINKS },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');
const isSectionActive = (children: { href: string }[]) => children.some((child) => isActive(child.href));
---

<header class="nav">
  <div class="wrapper nav__inner">
    <a class="nav__brand" href="/">
      <img src="/images/brand/tvc-logo-mark.png" alt="Tamarind Valley Collective" width="56" height="56" />
      <span>Tamarind Valley Collective</span>
    </a>

    <button class="nav__toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav__menu" id="nav-menu">
      {navItems.map((item) => (
        item.children ? (
          <div class="nav__item">
            <button
              type="button"
              class:list={['nav__link', 'nav__link--toggle', { 'is-active': isSectionActive(item.children) }]}
              aria-haspopup="true"
            >
              {item.label}
              <svg class="nav__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class:list={['nav__dropdown', { 'nav__dropdown--wide': item.wide }]}>
              {item.children.map((child) => (
                <a href={child.href} class:list={['nav__sublink', { 'is-active': isActive(child.href) }]}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class:list={['nav__link', { 'is-active': isActive(item.href) }]}>
            {item.label}
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    background: #fff;
    border-bottom: 1px solid var(--tvc-line);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--tvc-green-dark);
    font-family: var(--font-wordmark);
    font-weight: 700;
    font-size: 1.1rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav__brand img {
    border-radius: 50%;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav__item {
    position: relative;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    text-decoration: none;
    color: var(--tvc-ink);
    font-weight: 600;
    font-size: 0.88rem;
    padding: 6px 0;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  .nav__link--toggle {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    font-family: inherit;
    cursor: default;
  }

  .nav__link:hover {
    color: var(--tvc-green);
  }

  .nav__link.is-active {
    color: var(--tvc-green);
    border-bottom-color: var(--tvc-orange);
  }

  .nav__caret {
    color: var(--tvc-ink-soft);
    transition: transform 0.15s ease;
  }

  .nav__item:hover .nav__caret,
  .nav__item:focus-within .nav__caret {
    transform: rotate(180deg);
  }

  .nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    /* Centered under its own trigger, not left-anchored — a fixed-side
       anchor makes Explore and Engage hang in opposite directions (one
       growing right, the rightmost one forced left to avoid overflowing
       off-screen) instead of matching. Centering is the one rule that
       reads the same for every item; --dropdown-shift (set by the script
       below, only when needed) nudges it back on-screen at narrower
       desktop widths where centering alone would still clip an edge item. */
    left: 50%;
    transform: translateX(calc(-50% + var(--dropdown-shift, 0px)));
    flex-direction: column;
    min-width: 210px;
    background: #fff;
    border: 1px solid var(--tvc-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    padding: 8px;
    z-index: 60;
  }

  .nav__item:hover .nav__dropdown,
  .nav__item:focus-within .nav__dropdown {
    display: flex;
  }

  /* Explore has 7 items — a single column runs uncomfortably tall, so it
     gets a two-column grid instead. Declared after the rules above so it
     wins the display:flex vs display:grid tie on hover/focus. */
  .nav__dropdown--wide {
    grid-template-columns: repeat(2, minmax(170px, 1fr));
    min-width: 360px;
  }

  .nav__item:hover .nav__dropdown--wide,
  .nav__item:focus-within .nav__dropdown--wide {
    display: grid;
  }

  .nav__sublink {
    display: block;
    text-decoration: none;
    color: var(--tvc-ink);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 8px 12px;
    border-radius: 8px;
    white-space: nowrap;
  }

  .nav__sublink:hover {
    background: var(--tvc-green-tint);
    color: var(--tvc-green-dark);
  }

  .nav__sublink.is-active {
    color: var(--tvc-green);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
  }

  .nav__toggle span {
    width: 22px;
    height: 2px;
    background: var(--tvc-green-dark);
    display: block;
  }

  @media (max-width: 860px) {
    .nav__toggle {
      display: flex;
    }

    .nav__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 1px solid var(--tvc-line);
      flex-direction: column;
      /* Undo the base rule's flex-wrap: wrap and justify-content: flex-end
         — those exist for the desktop row layout. Left as flex-end here,
         content taller than the max-height below overflows upward past
         the container's top edge (unreachable, since scrollTop can't go
         negative) instead of scrolling normally; flex-wrap: wrap instead
         splits Explore/Engage into two side-by-side columns. */
      flex-wrap: nowrap;
      justify-content: flex-start;
      align-items: stretch;
      padding: 12px 24px 20px;
      gap: 4px;
      max-height: calc(100vh - 100%);
      overflow-y: auto;
    }

    .nav__menu.is-open {
      display: flex;
    }

    .nav__item {
      display: flex;
      flex-direction: column;
    }

    .nav__link {
      padding: 10px 0;
    }

    .nav__dropdown {
      display: flex;
      position: static;
      /* transform isn't gated by position: static the way left/right are —
         without resetting it, the desktop centering translate would still
         shift this static-flow mobile dropdown sideways by half its width. */
      transform: none;
      border: none;
      box-shadow: none;
      padding: 0 0 6px 16px;
      min-width: 0;
    }

    .nav__dropdown--wide {
      display: flex;
      grid-template-columns: none;
      min-width: 0;
    }

    .nav__sublink {
      padding: 8px 0;
    }
  }

  /* Logo mark + "Tamarind Valley Collective" wordmark + the hamburger button
     don't all fit on one line below ~420px (older/smaller phones, e.g. a
     320px-wide viewport) — .nav__brand has flex-shrink:0 and white-space:
     nowrap, so instead of wrapping or clipping it pushed the toggle button
     off-screen and forced a page-wide horizontal scrollbar. Drop the
     wordmark text at this width; the logo alone still links home. */
  @media (max-width: 420px) {
    .nav__brand span {
      display: none;
    }

    .nav__brand img {
      width: 44px;
      height: 44px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  // Dropdowns center under their own trigger by default (see .nav__dropdown
  // in the style block above) -- consistent for every item, but at
  // desktop widths where a trigger sits close to the viewport edge,
  // centering alone can still clip the dropdown off-screen. Nudge it back
  // on-screen via a CSS variable rather than reverting to a fixed
  // left/right anchor, which is what made Explore and Engage misalign in
  // the first place.
  const EDGE_PADDING = 12;

  function clampDropdown(item: Element) {
    const dropdown = item.querySelector<HTMLElement>('.nav__dropdown');
    if (!dropdown) return;
    dropdown.style.removeProperty('--dropdown-shift');
    const rect = dropdown.getBoundingClientRect();
    let shift = 0;
    if (rect.left < EDGE_PADDING) {
      shift = EDGE_PADDING - rect.left;
    } else if (rect.right > window.innerWidth - EDGE_PADDING) {
      shift = window.innerWidth - EDGE_PADDING - rect.right;
    }
    if (shift !== 0) dropdown.style.setProperty('--dropdown-shift', `${shift}px`);
  }

  document.querySelectorAll('.nav__item').forEach((item) => {
    item.addEventListener('mouseenter', () => clampDropdown(item));
    item.addEventListener('focusin', () => clampDropdown(item));
  });
</script>
