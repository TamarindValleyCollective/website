---
const navItems = [
  {
    label: 'About TVC',
    href: '/about',
    children: [
      { label: 'In Pictures', href: '/in-pictures' },
      { label: 'Partners', href: '/ecosystem/partners' },
      { label: 'Resource Centre', href: '/resource-centre' },
    ],
  },
  {
    label: 'Our Journey',
    href: '/our-journey',
    children: [
      { label: 'The Design', href: '/our-journey/design' },
      { label: 'Community Outreach', href: '/community-outreach' },
    ],
  },
  {
    label: 'Visit TVC',
    href: '/visit',
    children: [
      { label: 'Day Visit', href: '/visit/day-visit' },
      { label: 'Overnight Camping', href: '/visit/camping' },
      { label: 'Trekking Trails', href: '/visit/trekking-trails' },
      { label: 'How to Reach', href: '/visit/how-to-reach' },
    ],
  },
  { label: 'Biodiversity', href: '/ecosystem' },
  { label: 'Events', href: '/events' },
  { label: 'Contact Us', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');
---

<header class="nav">
  <div class="wrapper nav__inner">
    <a class="nav__brand" href="/">
      <img src="/images/brand/tvc-logo-mark.png" alt="Tamarind Valley Collective" width="56" height="56" />
      <span>Tamarind Valley Collective</span>
    </a>

    <button class="nav__toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav__menu" id="nav-menu">
      {navItems.map((item) => (
        item.children ? (
          <div class="nav__item">
            <a href={item.href} class:list={['nav__link', { 'is-active': isActive(item.href) }]}>
              {item.label}
              <svg class="nav__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <div class="nav__dropdown">
              {item.children.map((child) => (
                <a href={child.href} class:list={['nav__sublink', { 'is-active': isActive(child.href) }]}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class:list={['nav__link', { 'is-active': isActive(item.href) }]}>
            {item.label}
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<style>
  .nav {
    background: #fff;
    border-bottom: 1px solid var(--tvc-line);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--tvc-green-dark);
    font-family: var(--font-wordmark);
    font-weight: 700;
    font-size: 1.1rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav__brand img {
    border-radius: 50%;
  }

  .nav__menu {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav__item {
    position: relative;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    text-decoration: none;
    color: var(--tvc-ink);
    font-weight: 600;
    font-size: 0.88rem;
    padding: 6px 0;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }

  .nav__link:hover {
    color: var(--tvc-green);
  }

  .nav__link.is-active {
    color: var(--tvc-green);
    border-bottom-color: var(--tvc-orange);
  }

  .nav__caret {
    color: var(--tvc-ink-soft);
    transition: transform 0.15s ease;
  }

  .nav__item:hover .nav__caret,
  .nav__item:focus-within .nav__caret {
    transform: rotate(180deg);
  }

  .nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    flex-direction: column;
    min-width: 210px;
    background: #fff;
    border: 1px solid var(--tvc-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    padding: 8px;
    z-index: 60;
  }

  .nav__item:hover .nav__dropdown,
  .nav__item:focus-within .nav__dropdown {
    display: flex;
  }

  .nav__sublink {
    display: block;
    text-decoration: none;
    color: var(--tvc-ink);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 8px 12px;
    border-radius: 8px;
    white-space: nowrap;
  }

  .nav__sublink:hover {
    background: var(--tvc-green-tint);
    color: var(--tvc-green-dark);
  }

  .nav__sublink.is-active {
    color: var(--tvc-green);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
  }

  .nav__toggle span {
    width: 22px;
    height: 2px;
    background: var(--tvc-green-dark);
    display: block;
  }

  @media (max-width: 860px) {
    .nav__toggle {
      display: flex;
    }

    .nav__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #fff;
      border-bottom: 1px solid var(--tvc-line);
      flex-direction: column;
      align-items: stretch;
      padding: 12px 24px 20px;
      gap: 4px;
      max-height: calc(100vh - 100%);
      overflow-y: auto;
    }

    .nav__menu.is-open {
      display: flex;
    }

    .nav__item {
      display: flex;
      flex-direction: column;
    }

    .nav__link {
      padding: 10px 0;
    }

    .nav__dropdown {
      display: flex;
      position: static;
      border: none;
      box-shadow: none;
      padding: 0 0 6px 16px;
      min-width: 0;
    }

    .nav__sublink {
      padding: 8px 0;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });
</script>
