---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  image?: string;
  imageAlt?: string;
}

const { eyebrow, title, intro, image, imageAlt = '' } = Astro.props;
---

<section class="hero">
  {image && <img class="hero__image" src={image} alt={imageAlt} />}
  <div class="wrapper hero__content">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {intro && <p class="hero__intro">{intro}</p>}
  </div>
</section>

<style>
  .hero {
    position: relative;
  }

  .hero__image {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
  }

  .hero__content {
    padding: 40px 24px 8px;
  }

  .hero__intro {
    font-size: 1.1rem;
    color: var(--tvc-ink-soft);
    max-width: 70ch;
  }
</style>
