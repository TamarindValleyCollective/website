---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  image?: string;
  imageAlt?: string;
}

const { eyebrow, title, intro, image, imageAlt = '' } = Astro.props;
---

{image ? (
  <section class="hero hero--image">
    <img class="hero__image" src={image} alt={imageAlt} />
    <div class="hero__scrim"></div>
    <div class="wrapper hero__content">
      {eyebrow && <p class="eyebrow eyebrow--light">{eyebrow}</p>}
      <h1>{title}</h1>
      {intro && <p class="hero__intro">{intro}</p>}
    </div>
  </section>
) : (
  <section class="hero hero--plain">
    <div class="wrapper hero__content">
      {eyebrow && (
        <p class="eyebrow">
          {eyebrow}
          <span class="eyebrow__rule" aria-hidden="true"></span>
        </p>
      )}
      <h1>{title}</h1>
      {intro && <p class="hero__intro hero__intro--dark">{intro}</p>}
    </div>
  </section>
)}

<style>
  .hero--image {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 26, 18, 0.15) 0%, rgba(15, 26, 18, 0.75) 100%);
  }

  .hero__content {
    /* Without an explicit width, a flex item shrinks to fit its content
       *before* `margin: 0 auto` centers it — so a short heading would
       center as a narrow box instead of sitting flush at the same left
       edge every other .wrapper on the site uses. width:100% forces it to
       fill the flex container first, so the max-width/auto-margin centering
       behaves exactly like normal block-flow .wrapper usage everywhere else. */
    width: 100%;
    position: relative;
    padding-top: 60px;
    padding-bottom: 48px;
  }

  /* Pages without a photo (Ecosystem, About, Visit...) had nothing to give
     the header visual weight, so it read as an unstyled void bleeding into
     the section below on the same cream background. The tint band + rule
     borrow the accent already used for section--tint elsewhere, giving the
     hero its own presence without introducing a new color. */
  .hero--plain {
    background: var(--tvc-green-tint);
    border-bottom: 1px solid var(--tvc-line);
  }

  .hero--plain .hero__content {
    padding-top: 88px;
    padding-bottom: 56px;
  }

  .hero--image h1 {
    color: #fff;
    max-width: 20ch;
  }

  .hero--plain h1 {
    max-width: 22ch;
  }

  .eyebrow--light {
    color: #ffd8a8;
  }

  .eyebrow__rule {
    display: block;
    width: 40px;
    height: 3px;
    margin-top: 14px;
    background: var(--tvc-orange);
    border-radius: 2px;
  }

  .hero__intro {
    font-size: 1.15rem;
    color: #eef2ea;
    max-width: 62ch;
    margin-top: 10px;
  }

  .hero__intro--dark {
    color: var(--tvc-ink-soft);
  }

  @media (max-width: 640px) {
    .hero--image {
      min-height: 320px;
    }

    .hero--plain .hero__content {
      padding-top: 56px;
      padding-bottom: 40px;
    }
  }
</style>
