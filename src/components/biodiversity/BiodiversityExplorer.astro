---
// Data fetching and rendering for this page happens entirely client-side (see
// the <script> below), fetching live from the iNaturalist API on every page
// load. This is deliberate — Astro's experimental Live Content Collections
// would do something that sounds similar but actually runs server-side per
// request (needs `output: 'server'` + a Vercel function), which would break
// with the rest of this site staying fully static. Don't "fix" this into SSR.
---

<div class="explorer" id="biodiversity-explorer">
  <div class="explorer__status" id="explorer-status" role="status">
    <div class="skeleton"></div>
    <p>Loading live sightings from iNaturalist…</p>
  </div>

  <div class="explorer__body" id="explorer-body" hidden>
    <div class="stats" id="explorer-stats"></div>

    <div class="leaderboard" id="leaderboard" role="group" aria-label="Top contributors"></div>

    <div class="explorer__controls">
      <div class="explorer__chips" id="explorer-chips" role="group" aria-label="Filter by group"></div>
      <div class="view-toggle" role="group" aria-label="View">
        <button type="button" class="view-toggle__btn is-active" id="view-gallery">Gallery</button>
        <button type="button" class="view-toggle__btn" id="view-map">Map view</button>
      </div>
    </div>

    <div class="contributor-filter" id="contributor-filter" hidden>
      <span>Showing observations by <strong id="contributor-filter-name"></strong></span>
      <button type="button" id="contributor-filter-clear">Clear ✕</button>
    </div>

    <div class="explorer__map-wrap" id="map-view" hidden>
      <div id="observation-map"></div>
    </div>

    <div class="explorer__grid" id="explorer-grid"></div>

    <div class="load-more-wrap" id="load-more-wrap" hidden>
      <button type="button" class="button button--outline" id="load-more">Load more</button>
    </div>
  </div>

  <div class="explorer__empty" id="explorer-empty" hidden>
    <p>No observations found for this project yet.</p>
  </div>

  <div class="explorer__error" id="explorer-error" hidden>
    <p>Couldn't load live observations right now. <button type="button" id="explorer-retry" class="button button--outline">Try again</button></p>
  </div>

  <div class="detail-overlay" id="detail-overlay" hidden>
    <div class="detail-panel" role="dialog" aria-modal="true" aria-labelledby="detail-title">
      <button type="button" class="detail-close" id="detail-close" aria-label="Close">✕</button>
      <div id="detail-content"></div>
    </div>
  </div>
</div>

<style>
  .explorer__status {
    text-align: center;
    padding: 60px 0;
  }

  .skeleton {
    width: 100%;
    max-width: 480px;
    height: 240px;
    margin: 0 auto 20px;
    border-radius: var(--radius);
    background: linear-gradient(90deg, var(--tvc-line) 25%, #f3f0e2 37%, var(--tvc-line) 63%);
    background-size: 400% 100%;
    animation: shimmer 1.4s ease infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .skeleton {
      animation: none;
    }
  }

  @keyframes shimmer {
    0% { background-position: 100% 0; }
    100% { background-position: 0 0; }
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 56px;
    margin-bottom: 36px;
  }

  /* .stat* and everything below through .obs-card* is built by the <script>
     via createElement/innerHTML, not present in this component's server-
     rendered markup — Astro only scopes elements it renders itself, so these
     selectors must be :global() or they silently never match anything. */
  :global(.stat) {
    border-left: 2px solid var(--tvc-orange);
    padding-left: 16px;
  }

  :global(.stat__label) {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--tvc-ink-soft);
    margin: 0;
  }

  :global(.stat__value) {
    font-family: var(--font-display);
    font-size: 2.3rem;
    font-weight: 700;
    color: var(--tvc-ink);
    margin: 6px 0 0;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .leaderboard {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  :global(.leaderboard__item) {
    appearance: none;
    -webkit-appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid var(--tvc-line);
    background: #fff;
    color: var(--tvc-ink-soft);
    padding: 5px 12px 5px 6px;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
  }

  :global(.leaderboard__item:hover) {
    border-color: var(--tvc-orange);
  }

  :global(.leaderboard__item.is-active) {
    background: var(--tvc-ink);
    border-color: var(--tvc-ink);
    color: #fff;
  }

  :global(.leaderboard__rank) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--tvc-green-tint);
    color: var(--tvc-green);
    font-size: 0.7rem;
    font-weight: 700;
  }

  :global(.leaderboard__item.is-active .leaderboard__rank) {
    background: var(--tvc-orange);
    color: #fff;
  }

  :global(.leaderboard__count) {
    color: var(--tvc-ink-soft);
    font-weight: 500;
  }

  :global(.leaderboard__item.is-active .leaderboard__count) {
    color: #e8f2ea;
  }

  .explorer__controls {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
  }

  .explorer__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  :global(.chip) {
    appearance: none;
    -webkit-appearance: none;
    border: 1px solid var(--tvc-line);
    background: #fff;
    background-color: #fff;
    color: var(--tvc-ink-soft);
    padding: 5px 14px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.82rem;
    font-family: inherit;
    cursor: pointer;
  }

  :global(.chip.is-active) {
    background: var(--tvc-ink);
    background-color: var(--tvc-ink);
    border-color: var(--tvc-ink);
    color: #fff;
  }

  .view-toggle {
    display: inline-flex;
    border: 1px solid var(--tvc-line);
    border-radius: 999px;
    padding: 3px;
    flex-shrink: 0;
  }

  .view-toggle__btn {
    border: none;
    background: transparent;
    padding: 6px 16px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.82rem;
    cursor: pointer;
    color: var(--tvc-ink-soft);
  }

  .view-toggle__btn.is-active {
    background: var(--tvc-ink);
    color: #fff;
  }

  .contributor-filter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: var(--tvc-green-tint);
    border: 1px solid rgba(24, 114, 60, 0.25);
    border-radius: 999px;
    padding: 8px 8px 8px 18px;
    margin-bottom: 20px;
    font-size: 0.85rem;
    color: var(--tvc-ink);
  }

  .contributor-filter[hidden] {
    display: none;
  }

  .contributor-filter #contributor-filter-clear {
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: #fff;
    color: var(--tvc-ink-soft);
    font-weight: 600;
    font-size: 0.78rem;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
  }

  .contributor-filter #contributor-filter-clear:hover {
    background: var(--tvc-ink);
    color: #fff;
  }

  .explorer__map-wrap {
    margin-bottom: 24px;
  }

  #observation-map {
    height: 460px;
    width: 100%;
    border-radius: var(--radius);
    z-index: 0;
  }

  .explorer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 24px 20px;
  }

  :global(.obs-card) {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    background-color: transparent;
    border: none;
    overflow: visible;
    cursor: pointer;
    text-align: left;
    padding: 0;
    font: inherit;
    width: 100%;
    /* The grid stretches every card to the row's tallest height (its photo),
       so a card with no photo on file (a handful of observations have none)
       is shorter content sitting inside a taller box. Browsers vertically
       center a <button>'s content by default as part of its internal
       rendering as a form control — that centering survives even under
       `display: block`, so it has to be overridden explicitly here to get
       plain top alignment instead. */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  :global(.obs-card__media) {
    position: relative;
  }

  :global(.obs-card img) {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 4px;
  }

  /* A real <button>, nested inside .obs-card's own click target — .obs-card
     had to become a div[role=button] rather than a <button> for this to be
     valid HTML (buttons can't nest), see the click handler for the
     stopPropagation() that keeps this from also opening the detail panel. */
  :global(.obs-card__observer) {
    position: absolute;
    left: 6px;
    top: 6px;
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: rgba(23, 41, 31, 0.72);
    color: #fff;
    font-weight: 600;
    font-size: 0.7rem;
    padding: 4px 10px;
    border-radius: 999px;
    cursor: pointer;
    max-width: calc(100% - 12px);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.obs-card__observer:hover) {
    background: var(--tvc-orange);
  }

  :global(.obs-card__observer.is-active) {
    background: var(--tvc-orange);
  }

  :global(.obs-card__body) {
    padding-top: 10px;
  }

  :global(.obs-card__name) {
    font-weight: 700;
    color: var(--tvc-ink);
    margin: 0;
    font-size: 0.95rem;
  }

  :global(.obs-card__scientific) {
    font-style: italic;
    color: var(--tvc-ink-soft);
    font-size: 0.82rem;
    margin: 2px 0 4px;
  }

  :global(.obs-card__group) {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--tvc-orange);
    font-weight: 700;
    margin: 0;
  }

  .load-more-wrap {
    text-align: center;
    margin-top: 36px;
  }

  .explorer__empty,
  .explorer__error {
    text-align: center;
    padding: 60px 0;
  }

  .detail-overlay {
    position: fixed;
    inset: 0;
    background: rgba(23, 41, 31, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 20px;
  }

  /* [hidden] must win over the .detail-overlay { display: flex } rule above —
     without this, the overlay still renders (and eats pointer events) while
     "hidden" is set, since both rules have equal specificity and this one
     needs to come last. */
  .detail-overlay[hidden] {
    display: none;
  }

  .detail-panel {
    background: #fff;
    border-radius: var(--radius);
    max-width: 560px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    padding: 28px;
    position: relative;
  }

  .detail-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    font-size: 1.1rem;
    cursor: pointer;
    color: var(--tvc-ink-soft);
  }

  :global(.obs-marker span) {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  :global(.obs-popup img) {
    width: 100%;
    max-width: 180px;
    border-radius: 6px;
    margin-bottom: 6px;
  }

  :global(.detail-photo) {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
    margin: 12px 0;
  }
</style>

<script>
  import 'leaflet/dist/leaflet.css';
  import { initMap } from './observation-map';
  import {
    fetchAllObservations,
    groupByIconicTaxon,
    groupByParentTaxon,
    isWithinBoundary,
    labelForIconicTaxon,
    thumbUrl,
    type Observation,
  } from './observation-utils';

  const PAGE_SIZE = 24;

  const statusEl = document.getElementById('explorer-status')!;
  const bodyEl = document.getElementById('explorer-body')!;
  const emptyEl = document.getElementById('explorer-empty')!;
  const errorEl = document.getElementById('explorer-error')!;
  const statsEl = document.getElementById('explorer-stats')!;
  const chipsEl = document.getElementById('explorer-chips')!;
  const gridEl = document.getElementById('explorer-grid')!;
  const mapViewEl = document.getElementById('map-view')!;
  const galleryBtn = document.getElementById('view-gallery')!;
  const mapBtn = document.getElementById('view-map')!;
  const loadMoreWrap = document.getElementById('load-more-wrap')!;
  const loadMoreBtn = document.getElementById('load-more')!;
  const retryBtn = document.getElementById('explorer-retry')!;
  const overlayEl = document.getElementById('detail-overlay')!;
  const detailContentEl = document.getElementById('detail-content')!;
  const detailCloseEl = document.getElementById('detail-close')!;
  const contributorFilterEl = document.getElementById('contributor-filter')!;
  const contributorFilterNameEl = document.getElementById('contributor-filter-name')!;
  const contributorFilterClearBtn = document.getElementById('contributor-filter-clear')!;
  const leaderboardEl = document.getElementById('leaderboard')!;

  const RANK_MEDALS: Record<number, string> = { 0: '🥇', 1: '🥈', 2: '🥉' };
  const TOP_CONTRIBUTOR_COUNT = 5;

  let allObservations: Observation[] = [];
  let byParent: Map<number, Observation[]> = new Map();
  let activeFilter: string | null = null;
  let activeContributor: string | null = null;
  let visibleCount = PAGE_SIZE;
  let mapInitialized = false;
  let mapInstance: ReturnType<typeof initMap> | null = null;

  // Rebuilds the map from the current filters. Leaflet has no "swap the
  // markers" API cheap enough to bother with here, so this just tears down
  // and re-initializes -- fine for ~100 markers, and it's not visible
  // happening if the map tab isn't the one currently open. A no-op before
  // the map has ever been opened; it'll pick up whatever filters are active
  // the first time it is (see the view-map click handler below).
  function refreshMap() {
    if (!mapInitialized) return;
    mapInstance?.remove();
    mapInstance = initMap('observation-map', filteredObservations(), openDetail);
  }

  function showState(state: 'loading' | 'ready' | 'empty' | 'error') {
    statusEl.hidden = state !== 'loading';
    bodyEl.hidden = state !== 'ready';
    emptyEl.hidden = state !== 'empty';
    errorEl.hidden = state !== 'error';
  }

  function renderStats() {
    const speciesCount = new Set(allObservations.map((o) => o.taxon?.id).filter(Boolean)).size;
    const contributorCount = new Set(allObservations.map((o) => o.user.login).filter(Boolean)).size;
    const stats = [
      { label: 'Observations', value: allObservations.length },
      { label: 'Species', value: speciesCount },
      { label: 'Contributors', value: contributorCount },
    ];
    statsEl.innerHTML = stats
      .map((s) => `<div class="stat"><p class="stat__label">${s.label}</p><p class="stat__value">${s.value}</p></div>`)
      .join('');
  }

  // Ranked by total contributions across the whole dataset -- deliberately
  // not affected by the active taxon/observer filters, same as the stats
  // row above, so it stays a stable "who's contributed the most" reference
  // rather than jumping around as someone filters the grid. Doubles as a
  // shortcut into the existing observer filter -- clicking an entry is the
  // same setContributorFilter() the per-card overlay button uses.
  function renderLeaderboard() {
    const counts = new Map<string, { name: string; count: number }>();
    for (const o of allObservations) {
      const login = o.user.login;
      if (!login) continue;
      const entry = counts.get(login) ?? { name: o.user.name || login, count: 0 };
      entry.count += 1;
      counts.set(login, entry);
    }
    const top = [...counts.entries()].sort((a, b) => b[1].count - a[1].count).slice(0, TOP_CONTRIBUTOR_COUNT);

    leaderboardEl.innerHTML = '';
    if (top.length === 0) return;

    top.forEach(([login, { name, count }], i) => {
      const item = document.createElement('button');
      item.type = 'button';
      item.className = `leaderboard__item${login === activeContributor ? ' is-active' : ''}`;
      item.innerHTML = `<span class="leaderboard__rank">${RANK_MEDALS[i] ?? i + 1}</span> ${name} <span class="leaderboard__count">· ${count}</span>`;
      item.addEventListener('click', () => setContributorFilter(login, name));
      leaderboardEl.appendChild(item);
    });
  }

  function renderChips(groups: Map<string, Observation[]>) {
    chipsEl.innerHTML = '';
    const allChip = document.createElement('button');
    allChip.className = 'chip is-active';
    allChip.type = 'button';
    allChip.dataset.taxon = '';
    allChip.textContent = `All · ${allObservations.length}`;
    allChip.addEventListener('click', () => setFilter(null));
    chipsEl.appendChild(allChip);

    const sortedGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);
    for (const [iconicTaxon, obs] of sortedGroups) {
      const chip = document.createElement('button');
      chip.className = 'chip';
      chip.type = 'button';
      chip.dataset.taxon = iconicTaxon;
      chip.textContent = `${labelForIconicTaxon(iconicTaxon)} · ${obs.length}`;
      chip.addEventListener('click', () => setFilter(iconicTaxon));
      chipsEl.appendChild(chip);
    }
  }

  function setFilter(iconicTaxon: string | null) {
    activeFilter = iconicTaxon;
    visibleCount = PAGE_SIZE;
    [...chipsEl.children].forEach((chip) => {
      const el = chip as HTMLElement;
      el.classList.toggle('is-active', el.dataset.taxon === (iconicTaxon ?? ''));
    });
    renderGrid();
    refreshMap();
  }

  function filteredObservations(): Observation[] {
    let obs = allObservations;
    if (activeFilter) obs = obs.filter((o) => (o.taxon?.iconic_taxon_name ?? 'Unknown') === activeFilter);
    if (activeContributor) obs = obs.filter((o) => o.user.login === activeContributor);
    return obs;
  }

  // Toggle: clicking the observer overlay on a card that's already the
  // active filter clears it -- once filtered, every visible card's overlay
  // shows the same observer, so re-clicking any of them is the obvious
  // "undo". The pill in the controls row is the more discoverable clear
  // affordance. Filtering is keyed on login (stable/unique); displayName is
  // only for what the indicator pill shows.
  function setContributorFilter(login: string | null, displayName?: string) {
    activeContributor = activeContributor === login ? null : login;
    visibleCount = PAGE_SIZE;
    contributorFilterEl.hidden = !activeContributor;
    contributorFilterNameEl.textContent = activeContributor ? (displayName ?? activeContributor) : '';
    renderGrid();
    refreshMap();
    renderLeaderboard();
  }

  function renderGrid() {
    const obs = filteredObservations();
    const visible = obs.slice(0, visibleCount);
    gridEl.innerHTML = '';
    for (const o of visible) {
      // A div, not a <button> -- the observer handle below is a real nested
      // <button>, and buttons can't contain buttons. role/tabindex/keydown
      // restore the same keyboard behavior a native <button> gets for free.
      const card = document.createElement('div');
      card.className = 'obs-card';
      card.setAttribute('role', 'button');
      card.tabIndex = 0;
      const thumb = o.photos[0] ? thumbUrl(o.photos[0].url) : '';
      const name = o.taxon?.preferred_common_name || o.taxon?.name || 'Unidentified';
      const scientific = o.taxon?.name && o.taxon.name !== name ? o.taxon.name : '';
      const login = o.user.login;
      const observerName = o.user.name || login;
      const isActiveObserver = login && login === activeContributor;
      card.innerHTML = `
        ${thumb ? `
          <div class="obs-card__media">
            <img src="${thumb}" alt="${name}" loading="lazy" />
            ${login ? `<button type="button" class="obs-card__observer${isActiveObserver ? ' is-active' : ''}" title="Filter by ${observerName}">${observerName}</button>` : ''}
          </div>
        ` : ''}
        <div class="obs-card__body">
          <p class="obs-card__name">${name}</p>
          ${scientific ? `<p class="obs-card__scientific">${scientific}</p>` : ''}
          <p class="obs-card__group">${labelForIconicTaxon(o.taxon?.iconic_taxon_name ?? null)}</p>
        </div>
      `;
      card.addEventListener('click', () => openDetail(o));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openDetail(o);
        }
      });
      card.querySelector('.obs-card__observer')?.addEventListener('click', (e) => {
        e.stopPropagation();
        setContributorFilter(login, observerName);
      });
      gridEl.appendChild(card);
    }
    const remaining = obs.length - visible.length;
    loadMoreWrap.hidden = remaining <= 0;
    loadMoreBtn.textContent = `Load more · ${remaining} left`;
  }

  function openDetail(o: Observation) {
    const name = o.taxon?.preferred_common_name || o.taxon?.name || 'Unidentified';
    const scientific = o.taxon?.name && o.taxon.name !== name ? `<em>${o.taxon.name}</em>` : '';
    const photo = o.photos[0];
    const related = o.taxon?.parent_id != null ? (byParent.get(o.taxon.parent_id) ?? []).filter((r) => r.id !== o.id) : [];

    detailContentEl.innerHTML = `
      <h2 id="detail-title">${name}</h2>
      ${scientific ? `<p>${scientific}</p>` : ''}
      ${photo ? `<img class="detail-photo" src="${photo.url.replace('square', 'medium')}" alt="${name}" />` : ''}
      ${photo ? `<p class="attribution" style="font-size:0.82rem;color:var(--tvc-ink-soft);">${photo.attribution}${photo.license_code ? ` · <a href="https://creativecommons.org/licenses/${photo.license_code.replace('cc-', '')}/4.0/" target="_blank" rel="noopener noreferrer">${photo.license_code.toUpperCase()}</a>` : ''}</p>` : ''}
      <p><strong>Observed:</strong> ${o.observed_on ?? 'Unknown date'}</p>
      <p><strong>Location:</strong> ${o.place_guess ?? 'On the farm'}</p>
      <p><strong>Observer:</strong> <a href="https://www.inaturalist.org/people/${o.user.login}" target="_blank" rel="noopener noreferrer">${o.user.name || o.user.login}</a></p>
      <p><a href="${o.uri}" target="_blank" rel="noopener noreferrer">View on iNaturalist →</a></p>
      ${related.length > 0 ? `
        <h3>Related sightings</h3>
        <p style="font-size:0.85rem;color:var(--tvc-ink-soft);">Other observations in the same genus.</p>
        <div class="related-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:8px;">
          ${related.slice(0, 8).map((r) => `<img data-related-id="${r.id}" src="${r.photos[0] ? thumbUrl(r.photos[0].url) : ''}" alt="${r.taxon?.preferred_common_name || r.taxon?.name || ''}" style="width:100%;height:70px;object-fit:cover;border-radius:6px;cursor:pointer;" />`).join('')}
        </div>
      ` : ''}
    `;

    detailContentEl.querySelectorAll('[data-related-id]').forEach((img) => {
      img.addEventListener('click', () => {
        const id = Number((img as HTMLElement).dataset.relatedId);
        const relatedObs = allObservations.find((o2) => o2.id === id);
        if (relatedObs) openDetail(relatedObs);
      });
    });

    overlayEl.hidden = false;
  }

  detailCloseEl.addEventListener('click', () => {
    overlayEl.hidden = true;
  });
  overlayEl.addEventListener('click', (e) => {
    if (e.target === overlayEl) overlayEl.hidden = true;
  });

  loadMoreBtn.addEventListener('click', () => {
    visibleCount += PAGE_SIZE;
    renderGrid();
  });

  contributorFilterClearBtn.addEventListener('click', () => setContributorFilter(null));

  galleryBtn.addEventListener('click', () => {
    galleryBtn.classList.add('is-active');
    mapBtn.classList.remove('is-active');
    mapViewEl.hidden = true;
    gridEl.hidden = false;
    loadMoreWrap.hidden = filteredObservations().length <= visibleCount;
  });

  mapBtn.addEventListener('click', () => {
    mapBtn.classList.add('is-active');
    galleryBtn.classList.remove('is-active');
    mapViewEl.hidden = false;
    gridEl.hidden = true;
    loadMoreWrap.hidden = true;
    if (!mapInitialized) {
      mapInitialized = true;
      // Map init is deferred until first shown — its container has zero
      // height while `hidden`, so Leaflet can't size itself correctly earlier.
      requestAnimationFrame(() => {
        mapInstance = initMap('observation-map', filteredObservations(), openDetail);
      });
    }
  });

  async function load() {
    showState('loading');
    try {
      // Drop findings with no identification at all -- an unidentified
      // observation isn't a "what lives here" answer, so it doesn't belong
      // in a showcase of species. Also restrict to the TVC property
      // boundary itself -- the iNaturalist project also picks up sightings
      // from the adjoining reserve forest and a few further-flung outliers.
      // Both affect stats/chips/map too, not just the grid, since they're
      // all derived from allObservations.
      allObservations = (await fetchAllObservations())
        .filter((o) => o.taxon != null)
        .filter((o) => isWithinBoundary(o.geojson));
      if (allObservations.length === 0) {
        showState('empty');
        return;
      }
      byParent = groupByParentTaxon(allObservations);
      const groups = groupByIconicTaxon(allObservations);
      renderStats();
      renderLeaderboard();
      renderChips(groups);
      renderGrid();
      showState('ready');
    } catch (err) {
      console.error('Failed to load iNaturalist observations', err);
      showState('error');
    }
  }

  retryBtn.addEventListener('click', load);
  load();
</script>
