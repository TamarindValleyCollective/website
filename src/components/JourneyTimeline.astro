  ]},
  { year: 2025, label: `Under Siege`, narrative: `If 2024 tested TVC, 2025 pressed harder. A wildfire breached the farm's fire lines in March, elephants returned in April, and in July, the community's transformer — installed only two years before — was stolen outright. Yet the work continued: a bigger water-harvesting project got underway in May, the fifth 3Bs&1H gathering ran in August, and home construction kept inching forward.`, events: [
    { month: 'Mar', title: `Wildfire burns through the land`, type: 'ember', text: `A wildfire breached the farm's fire lines, burning through a significant stretch of vegetation.`, images: ['/images/journey/journey-34.jpg'] },
    { month: 'Apr', title: `Elephants visit again`, type: 'ember', text: `Elephants returned to the land for another visit.`, images: ['/images/journey/journey-35.jpg'] },
    { month: 'May', title: `A larger water-harvesting project`, type: 'water', text: `TVC undertook a larger project to capture and hold water on the land.`, images: ['/images/journey/journey-36.jpg'] },
