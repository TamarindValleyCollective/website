    { month: 'Mar', title: `Solar shed set up`, type: 'ochre', text: `A dedicated solar shed was installed at the farm to provide power.`, images: ['/images/journey/journey-12.jpg', '/images/journey/journey-13.jpg', '/images/journey/journey-14.jpg'] },
