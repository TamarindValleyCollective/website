    { month: 'Jan', title: `First mud hut, built by hand`, type: 'ochre', text: `TVC's first structure went up — a hut built entirely of mud, entirely by hand.`, images: ['/images/journey/journey-04.jpg'] },
    { month: 'Jan', title: `First campsite stay`, type: 'leaf', text: `Members held their first overnight camp stay at the farm.`, images: ['/images/journey/journey-05.jpg'] },
