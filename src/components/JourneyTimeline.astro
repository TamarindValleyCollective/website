    { month: 'Mar', title: `First home completed — house warming`, type: 'ochre', text: `On March 15th, TVC celebrated its first completed home with a house warming for Ram & Krishna.`, images: ['/images/journey/journey-46.jpg', '/images/journey/journey-51.jpg', '/images/journey/journey-47.jpg'] },
    { month: 'Mar', title: `Pottery wheel inaugurated`, type: 'leaf', text: `The same day, TVC inaugurated its pottery wheel with a first workshop led by Ravi Varma.`, images: ['/images/journey/journey-50.jpg'] },
