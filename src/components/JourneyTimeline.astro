const DEFAULT_YEAR = 2026;
---

<div class="jt2" data-default-year={DEFAULT_YEAR}>
  <div class="jt2-wire-outer">
    <div class="jt2-wire" role="tablist" aria-label="Select a year">
      <div class="jt2-wireline" aria-hidden="true"></div>
      {DATA.map((y, i) => (
        <button
          type="button"
          class="jt2-stop"
          class:list={[i % 2 === 0 ? 'up' : 'down']}
          data-year={y.year}
          role="tab"
          aria-selected={y.year === DEFAULT_YEAR ? 'true' : 'false'}
        >
          <span class="jt2-tick" aria-hidden="true"></span>
          <span class="jt2-dot" aria-hidden="true"></span>
          <span class="jt2-labelblock">
            <span class="jt2-icon" set:html={ICONS[y.year]} />
            <span class="jt2-word">{y.label}</span>
            <span class="jt2-yr">{y.year}</span>
          </span>
        </button>
      ))}
    </div>
  </div>

  <div class="jt2-detail" id="jt2-detail">
    {DATA.map((y) => (
      <div class="jt2-panel" data-year-panel={y.year} hidden={y.year !== DEFAULT_YEAR}>
        <div class="jt2-narrative">
          <div class="jt2-headrow">
            <span class="jt2-icon-lg" set:html={ICONS[y.year]} />
            <span class="jt2-eyebrow">{y.label}</span>
          </div>
          <h3>{y.year}</h3>
          <p>{y.narrative}</p>
        </div>
        <div class="jt2-months">
          <p class="jt2-seclabel">Month by month</p>
          <div class="jt2-strip">
            {y.events.map((e) => (
              <button type="button" class="jt2-card" data-month={e.month} data-title={e.title} data-text={e.text} data-images={JSON.stringify(e.images)}>
                {e.images[0] ? (
                  <img class="jt2-thumb" src={e.images[0]} alt={e.title} loading="lazy" />
                ) : (
                  <span class="jt2-thumb-fallback">No photo</span>
                )}
                <span class="jt2-cardmeta">
                  <span class="jt2-month"><span class:list={['jt2-dotsm', `type-${e.type}`]}></span>{e.month} {y.year}</span>
                  <span class="jt2-title">{e.title}</span>
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<div class="jt2-modal-backdrop" id="jt2-modal-backdrop">
  <div class="jt2-modal-wrap">
    <button class="jt2-modal-close" id="jt2-modal-close" aria-label="Close">✕</button>
    <div class="jt2-modal" id="jt2-modal"></div>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('.jt2')!;
  const stops = Array.from(root.querySelectorAll<HTMLButtonElement>('.jt2-stop'));
  const panels = Array.from(root.querySelectorAll<HTMLElement>('.jt2-panel'));
  const modalBackdrop = document.getElementById('jt2-modal-backdrop')!;
  const modal = document.getElementById('jt2-modal')!;
  const modalClose = document.getElementById('jt2-modal-close')!;

  function selectYear(year: string) {
    stops.forEach((s) => {
      const active = s.dataset.year === year;
      s.classList.toggle('active', active);
      s.setAttribute('aria-selected', String(active));
    });
    panels.forEach((p) => {
      p.hidden = p.dataset.yearPanel !== year;
    });
  }

  stops.forEach((stop) => {
    stop.addEventListener('click', () => selectYear(stop.dataset.year!));
  });

  function openModal(card: HTMLButtonElement) {
    const images: string[] = JSON.parse(card.dataset.images || '[]');
    const title = card.dataset.title || '';
    const text = card.dataset.text || '';
    const month = card.dataset.month || '';
    modal.innerHTML = `
      ${images.length ? `<div class="jt2-modal-imgs">${images.map((src) => `<img src="${src}" alt="${title}" />`).join('')}</div>` : ''}
      <div class="jt2-modal-body">
        <p class="jt2-month-tag">${month}</p>
        <h3>${title}</h3>
        <p>${text}</p>
      </div>
    `;
    modalBackdrop.classList.add('open');
  }

  function closeModal() {
    modalBackdrop.classList.remove('open');
  }

  root.querySelectorAll<HTMLButtonElement>('.jt2-card').forEach((card) => {
    card.addEventListener('click', () => openModal(card));
  });

  modalClose.addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', (ev) => {
    if (ev.target === modalBackdrop) closeModal();
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') closeModal();
  });
</script>

<style>
  .jt2 {
    --jt-bg: #16140f;
    --jt-surface: rgba(242, 234, 217, 0.045);
    --jt-cream: #f2ead9;
    --jt-cream-dim: #a89c82;
    --jt-line: rgba(242, 234, 217, 0.14);
    --jt-line-strong: rgba(242, 234, 217, 0.32);
    --jt-accent: #d9a441;
    --jt-ochre: #c98500;
    --jt-leaf: #2f9e4f;
    --jt-water: #3987e5;
    --jt-ember: #e66767;
    --jt-neutral: #a89c82;

    background: var(--jt-bg);
    color: var(--jt-cream);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  /* ---------------- wire ---------------- */
  .jt2-wire-outer {
    padding: 32px clamp(16px, 3vw, 40px) 0;
  }

  .jt2-wire {
    position: relative;
    display: flex;
    height: 150px;
  }

  .jt2-wireline {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: linear-gradient(to right, rgba(47, 158, 79, 0.25), var(--jt-line-strong) 8%, var(--jt-line-strong) 92%, rgba(217, 164, 65, 0.4));
  }

  .jt2-stop {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    font: inherit;
    flex: 1;
    position: relative;
    cursor: pointer;
    padding: 0;
  }

  .jt2-stop:focus-visible .jt2-dot {
    outline: 2px solid var(--jt-accent);
    outline-offset: 3px;
  }

  .jt2-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--jt-bg);
    border: 2px solid var(--jt-line-strong);
    transform: translate(-50%, -50%);
    transition: all 0.25s ease;
    z-index: 2;
  }

  .jt2-stop:hover .jt2-dot {
    border-color: var(--jt-cream-dim);
  }

  .jt2-stop.active .jt2-dot {
    background: var(--jt-accent);
    border-color: var(--jt-accent);
    transform: translate(-50%, -50%) scale(1.35);
    box-shadow: 0 0 0 5px rgba(217, 164, 65, 0.16);
  }

  .jt2-tick {
    position: absolute;
    left: 50%;
    width: 2px;
    background: var(--jt-line-strong);
    transform: translateX(-50%);
    transition: background 0.25s ease;
  }

  .jt2-stop.up .jt2-tick {
    top: 32%;
    height: 18%;
  }

  .jt2-stop.down .jt2-tick {
    top: 50%;
    height: 18%;
  }

  .jt2-stop.active .jt2-tick {
    background: var(--jt-accent);
  }

  .jt2-labelblock {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    width: max-content;
    max-width: 120px;
    text-align: center;
  }

  .jt2-stop.up .jt2-labelblock {
    top: 0;
  }

  .jt2-stop.down .jt2-labelblock {
    bottom: 0;
  }

  .jt2-icon {
    color: var(--jt-cream-dim);
    line-height: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .jt2-icon :global(svg) {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
  }

  .jt2-stop.active .jt2-icon {
    color: var(--jt-accent);
    transform: scale(1.1);
  }

  .jt2-word {
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: 9.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--jt-cream-dim);
    line-height: 1.25;
  }

  .jt2-yr {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 19px;
    color: var(--jt-cream);
    line-height: 1;
  }

  .jt2-stop.active .jt2-word,
  .jt2-stop.active .jt2-yr {
    color: var(--jt-accent);
  }

  /* ---------------- detail panel ---------------- */
