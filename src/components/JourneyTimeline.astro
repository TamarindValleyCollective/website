    { month: 'Nov', title: `Logo exploration begins`, type: 'neutral', text: `Member Sunita produced the first set of logo concept renders for the community.`, images: ['/images/journey/journey-09.jpg', '/images/journey/journey-10.jpg', '/images/journey/journey-11.jpg'] },
