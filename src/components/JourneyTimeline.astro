  ]},
  { year: 2019, label: `Finding Form`, narrative: `Design work deepened in 2019. Permaculture consultants Ananas ran an ideation workshop at the farm in January and delivered the community's first GAIA design map in May. The city meet-up rhythm was now established — May in town, November at the farm — and by year's end, member Sunita's early sketches had grown into TVC's finalized logo.`, events: [
    { month: 'Jan', title: `Ideation workshop with Ananas`, type: 'leaf', text: `Ananas ran an ideation workshop at the farm to shape the site's design direction.`, images: ['/images/journey/journey-07.jpg'] },
