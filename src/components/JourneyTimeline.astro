    { month: 'Jun', title: `First earthwork to store water`, type: 'water', text: `The barren, organically depleted land got its first earthwork built to help capture and hold water on site.`, images: ['/images/journey/journey-45.jpg'] },
    { month: 'Jul', title: `Planting begins at the Kaveri plot`, type: 'leaf', text: `Fencing to stop overgrazing was already letting the land recover. Members began planting trees on a section they named the Kaveri plot, seeding it with organic matter trucked in from outside.`, images: ['/images/journey/journey-02.jpg'] },
    { month: 'Sep', title: `Permaculture course at Navadarshanam`, type: 'leaf', text: `A large group of members attended a Permaculture course held exclusively for TVC at Navadarshanam, guided by design consultants Ananas.`, images: ['/images/journey/journey-42.jpg'] },
    { month: 'Oct', title: `Monsoon washes the earthwork away`, type: 'ember', text: `An unusually heavy north-east monsoon hit the greater Krishnagiri district, with nearby stations logging 20–40mm in single 24-hour spells. The deluge destroyed the June earthwork and washed away much of what had been planted.`, images: ['/images/journey/journey-48.jpg'] },
  ]},
