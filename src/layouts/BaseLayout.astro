---
import Nav from '../components/Nav.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import JsonLd from '../components/JsonLd.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  // The actual pixel dimensions of `image`. og:image:width/height must
  // match the real file — WhatsApp's link-preview crawler silently
  // discards the image and falls back to the apple-touch-icon when they
  // don't (the home hero is a 4204x1330 panorama, nowhere near a lazily
  // hardcoded 1200x630), which is why only the logo showed up there.
  imageWidth?: number;
  imageHeight?: number;
  // Extra JSON-LD objects (Event, Article, FAQPage, BreadcrumbList, ...) a
  // page contributes on top of the sitewide Organization/WebSite graph
  // below.
  schema?: Record<string, unknown>[];
  // Set on pages with nothing worth ranking on (404) so crawlers don't
  // index a dead end.
  noindex?: boolean;
}

const {
  title,
  description = 'Tamarind Valley Collective — a 100-acre permaculture farm and community in the hills near Kanakapura.',
  image = '/images/pages/home/hero.jpg',
  imageWidth = 4204,
  imageHeight = 1330,
  schema = [],
  noindex = false,
} = Astro.props;

const pageTitle = `${title} · Tamarind Valley Collective`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);

// Shared across every page so Google can resolve the same Organization
// entity everywhere (Event organizers, Article publishers, the knowledge
// panel) instead of re-describing it inconsistently per page.
const siteURL = new URL('/', Astro.site).toString();
const organizationId = `${siteURL}#organization`;
const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': organizationId,
      name: 'Tamarind Valley Collective',
      url: siteURL,
      logo: new URL('/images/brand/tvc-logo-mark.png', Astro.site).toString(),
      description: 'Tamarind Valley Collective — a 100-acre permaculture farm and community in the hills near Kanakapura.',
      telephone: '+91 74063 07309',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Thaggatti village',
        addressLocality: 'Kanakapura',
        addressRegion: 'Karnataka',
        addressCountry: 'IN',
      },
      sameAs: [
        'https://www.facebook.com/farm.tvc',
        'https://twitter.com/TVCFarm',
        'https://www.instagram.com/tamarindvalleycollective/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteURL}#website`,
      url: siteURL,
      name: 'Tamarind Valley Collective',
      publisher: { '@id': organizationId },
    },
  ],
};
---

<html lang="en">
  <head>
    <!-- Google Analytics (GA4). Skipped on localhost so local/dev browsing
         never pollutes production traffic data. -->
    <script is:inline>
      (function () {
        if (/^(localhost|127\.0\.0\.1)$/.test(location.hostname)) return;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-795FTPB47P';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-795FTPB47P');
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <!-- Open Graph — WhatsApp, Facebook, Instagram, LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tamarind Valley Collective" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content={imageWidth} />
    <meta property="og:image:height" content={imageHeight} />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <JsonLd items={[siteGraph, ...schema]} />
  </head>
  <body>
    <Nav />
    <Breadcrumbs pathname={Astro.url.pathname} pageTitle={title} />
    <main>
      <slot />
    </main>
    <Footer />
    <ChatWidget />
  </body>
</html>
