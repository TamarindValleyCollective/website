# Copy to .env for local `netlify dev` testing of the chat widget, and for
# running scripts/caption-photos.mjs (AI-drafted In Pictures captions).
# In production (Netlify), set this in Site settings > Environment variables
# instead — never commit a real key.
ANTHROPIC_API_KEY=

# Only needed locally, to run scripts/curate-photos.mjs (In Pictures photo
# curation). Never used at build/deploy time - the site itself just embeds
# the public media.tvc.farm URLs these uploads produce, so this never needs
# to be a Netlify environment variable.
# R2 dashboard: Account Home -> R2 Object Storage -> Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tvc-photos
